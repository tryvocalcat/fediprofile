@page "/login"
@using Microsoft.AspNetCore.Components
@using System.Security.Claims
@layout FediProfile.Components.Layouts.MinimalLayout
@rendermode InteractiveServer

@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthStateProvider
@inject IConfiguration Configuration

@if (_checking)
{
    <section class="login-shell">
        <div class="login-card">
            <p class="muted">Checking authentication...</p>
        </div>
    </section>
    return;
}

<section class="login-shell">
    <div class="login-card">
        <h1 class="admin-title">Login or Sign Up</h1>
        <p class="admin-subtitle">Sign in with your Mastodon account. If you don't have a profile yet, we'll help you create one.</p>

        <label class="field-label" for="mastodonServer">Mastodon server</label>
        <input id="mastodonServer" class="input" placeholder="mastodon.social" @bind="server" />

        <button class="button button-primary" @onclick="StartLogin" disabled="@string.IsNullOrWhiteSpace(server)">
            Continue
        </button>

        <p class="muted small">You'll be redirected to your Mastodon instance to authorize.</p>

        <p class="muted small">Not on Mastodon? <a href="https://joinmastodon.org" target="_blank" rel="noopener noreferrer">Join here</a></p>

        @if (_githubEnabled || _linkedInEnabled)
        {
            <hr style="margin: 1.5rem 0; border: none; border-top: 1px solid var(--border, #e0e0e0);" />
            <p class="muted small">Or sign in with:</p>
            <div style="display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap;">
                @if (_githubEnabled)
                {
                    <button class="button button-secondary" @onclick="LoginWithGitHub">
                        <svg style="width:1em;height:1em;vertical-align:middle;margin-right:0.4em" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
                        GitHub
                    </button>
                }
                @if (_linkedInEnabled)
                {
                    <button class="button button-secondary" @onclick="LoginWithLinkedIn">
                        <svg style="width:1em;height:1em;vertical-align:middle;margin-right:0.4em" viewBox="0 0 16 16" fill="currentColor"><path d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854V1.146zm4.943 12.248V6.169H2.542v7.225h2.401zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248-.822 0-1.359.54-1.359 1.248 0 .694.521 1.248 1.327 1.248h.016zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225h2.4z"/></svg>
                        LinkedIn
                    </button>
                }
            </div>
        }
    </div>
</section>

@code {
    private string? server;
    private bool _checking = true;
    private string? _refParam;
    private bool _githubEnabled;
    private bool _linkedInEnabled;

    protected override async Task OnInitializedAsync()
    {
        // Check which OAuth providers are configured
        _githubEnabled = !string.IsNullOrEmpty(Configuration["Authentication:GitHub:ClientId"])
                      && !string.IsNullOrEmpty(Configuration["Authentication:GitHub:ClientSecret"]);
        _linkedInEnabled = !string.IsNullOrEmpty(Configuration["Authentication:LinkedIn:ClientId"])
                        && !string.IsNullOrEmpty(Configuration["Authentication:LinkedIn:ClientSecret"]);

        var uri = new Uri(NavigationManager.Uri);
        var qs = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        _refParam = qs.ContainsKey("ref") ? qs["ref"].ToString() : null;

        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        if (state.User.Identity?.IsAuthenticated == true)
        {
            var dest = "/login/check";
            if (!string.IsNullOrEmpty(_refParam))
                dest += $"?ref={Uri.EscapeDataString(_refParam)}";
            NavigationManager.NavigateTo(dest, true);
            return;
        }
        _checking = false;
    }

    private void StartLogin()
    {
        if (string.IsNullOrWhiteSpace(server))
        {
            return;
        }

        var sanitized = server.Trim();
        var url = $"/login/oauth/{sanitized}?returnUrl={Uri.EscapeDataString("/login/check")}";
        if (!string.IsNullOrEmpty(_refParam))
            url += $"&ref={Uri.EscapeDataString(_refParam)}";
        NavigationManager.NavigateTo(url, true);
    }

    private void LoginWithGitHub()
    {
        var url = $"/login/github?returnUrl={Uri.EscapeDataString("/login/check")}";
        if (!string.IsNullOrEmpty(_refParam))
            url += $"&ref={Uri.EscapeDataString(_refParam)}";
        NavigationManager.NavigateTo(url, true);
    }

    private void LoginWithLinkedIn()
    {
        var url = $"/login/linkedin?returnUrl={Uri.EscapeDataString("/login/check")}";
        if (!string.IsNullOrEmpty(_refParam))
            url += $"&ref={Uri.EscapeDataString(_refParam)}";
        NavigationManager.NavigateTo(url, true);
    }
}
