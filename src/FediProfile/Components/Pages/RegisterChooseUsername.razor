@page "/register/choose-username"
@using FediProfile.Services
@layout FediProfile.Components.Layouts.MinimalLayout
@rendermode InteractiveServer

@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthStateProvider
@inject DomainScopedDb DomainDb
@inject IHttpContextAccessor HttpContextAccessor
@inject IConfiguration Configuration

<section class="login-shell">
    <div class="login-card">
        <h1 class="admin-title">Create Your Profile</h1>
        <p class="admin-subtitle">Choose your unique username</p>

        @if (!_registrationOpen)
        {
            <div class="alert alert-info">Registration is currently closed. Please check back later.</div>
        }
        else if (_invalidInvitation)
        {
            <div class="alert alert-error">Invalid or missing invitation code. <a href="/register/invitation">Enter your code</a>.</div>
        }
        else if (string.IsNullOrWhiteSpace(_mastodonUser))
        {
            <p class="alert alert-info">Loading your information...</p>
        }
        else
        {
            <div class="form-group">
                @if (_mastodonDomain == "linkedin.com")
                {
                    <label>LinkedIn Account</label>
                    <div class="pill">@(_linkedInDisplayName ?? _mastodonUser) &mdash; LinkedIn</div>
                }
                else if (_mastodonDomain == "github.com")
                {
                    <label>GitHub Account</label>
                    <div class="pill">@(_gitHubDisplayName ?? _mastodonUser) &mdash; GitHub</div>
                }
                else
                {
                    <label>Mastodon Account</label>
                    <div class="pill">@(_mastodonUser)@@@(_mastodonDomain ?? "unknown")</div>
                }
            </div>

            @if (!string.IsNullOrEmpty(_message))
            {
                <div class="alert @(_isError ? "alert-error" : "alert-success")">
                    @_message
                </div>
            }

            <form @onsubmit="CreateProfile" class="admin-form">
                <div class="form-group">
                    <label for="userSlug">Your Profile URL</label>
                    <div class="input-group">
                        <span class="prefix">@(_domain)/</span>
                        <input type="text" id="userSlug" @bind="_userSlug" @bind:after="OnUserSlugChanged" 
                               required placeholder="choose-a-username" pattern="[a-zA-Z0-9_-]+" 
                               class="form-control" />
                    </div>
                    <small>Only letters, numbers, hyphens, and underscores allowed</small>
                    @if (!string.IsNullOrWhiteSpace(_userSlug))
                    {
                        if (_isCheckingSlug)
                        {
                            <small class="status-checking">Checking availability...</small>
                        }
                        else if (_slugAvailable)
                        {
                            <small class="status-available">✓ Available</small>
                        }
                        else
                        {
                            <small class="status-taken">✗ Already taken (try another)</small>
                        }
                    }
                </div>

                <button type="submit" class="button button-primary" disabled="@(!_slugAvailable || _isProcessing)">
                    @(_isProcessing ? "Creating..." : "Create Profile")
                </button>
            </form>
        }
    </div>
</section>



@code {
    private string? _mastodonUser;
    private string? _mastodonDomain;
    private string? _linkedInDisplayName;
    private string? _linkedInPicture;
    private string? _linkedInProfileUrl;
    private string? _gitHubDisplayName;
    private string? _gitHubAvatarUrl;
    private string? _userSlug;
    private string? _domain;
    private string? _message;
    private bool _isError;
    private bool _isProcessing;
    private bool _isCheckingSlug;
    private bool _slugAvailable;
    private bool _registrationOpen = true;
    private bool _invalidInvitation;
    private string? _refParam;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Parse ref param from URL
            var refUri = new Uri(NavigationManager.Uri);
            var refQs = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(refUri.Query);
            _refParam = refQs.ContainsKey("ref") ? refQs["ref"].ToString() : null;

            var singleUserInstance = Configuration.GetValue<bool>("SingleUserInstance", false);
            var registrationOpenConfigured = Configuration.GetValue<bool>("RegistrationOpen", true);
            _registrationOpen = await DomainDb.CanAcceptRegistrationsAsync(singleUserInstance, registrationOpenConfigured);
            if (!_registrationOpen) return;

            // Validate invitation code if one is configured
            var expectedCode = Configuration.GetValue<string>("InvitationCode") ?? "";
            if (!string.IsNullOrEmpty(expectedCode))
            {
                // Use NavigationManager.Uri instead of HttpContext.Request.Query
                // because HttpContext is null during interactive (SignalR) rendering
                var uri = new Uri(NavigationManager.Uri);
                var queryParams = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
                var providedCode = queryParams.ContainsKey("code") ? queryParams["code"].ToString() : "";
                if (!providedCode.Equals(expectedCode, StringComparison.OrdinalIgnoreCase))
                {
                    _invalidInvitation = true;
                    return;
                }
            }

            var httpContext = HttpContextAccessor.HttpContext;

            // Get domain from HTTP context
            if (httpContext == null)
            {
                _message = "Unable to determine your domain";
                _isError = true;
                return;
            }

            _domain = httpContext.Request.Host.Host;
            if (httpContext.Request.Host.Port.HasValue && httpContext.Request.Host.Port != 80 && httpContext.Request.Host.Port != 443)
            {
                _domain = $"{_domain}:{httpContext.Request.Host.Port}";
            }

            // Get authenticated user info
            var state = await AuthStateProvider.GetAuthenticationStateAsync();
            _mastodonUser = state.User.FindFirst(ClaimTypes.Name)?.Value;
            _mastodonDomain = state.User.FindFirst("urn:mastodon:hostname")?.Value;

            if (_mastodonDomain == "linkedin.com")
            {
                _linkedInDisplayName = state.User.FindFirst("urn:linkedin:display_name")?.Value;
                _linkedInPicture     = state.User.FindFirst("urn:linkedin:picture")?.Value;
                _linkedInProfileUrl  = state.User.FindFirst("urn:linkedin:profile_url")?.Value;
            }
            else if (_mastodonDomain == "github.com")
            {
                _gitHubDisplayName = state.User.FindFirst("urn:github:display_name")?.Value;
                _gitHubAvatarUrl   = state.User.FindFirst("urn:github:avatar_url")?.Value;
            }

            if (string.IsNullOrWhiteSpace(_mastodonUser) || string.IsNullOrWhiteSpace(_mastodonDomain))
            {
                _message = "You must be logged in to register";
                _isError = true;
            //    NavigationManager.NavigateTo("/login");
                return;
            }

            // Set default userSlug to mastodon username (e.g., mapache)
            var sanitizedUser = _mastodonUser.ToLowerInvariant().Replace(" ", "-").Replace("@", "");
            _userSlug = sanitizedUser;

            // Check if the default slug is available
            if (!LocalDbService.IsReservedUserSlug(_userSlug))
            {
                var existingUser = await DomainDb.GetUserBySlugAsync(_userSlug);
                if (existingUser == null)
                {
                    _slugAvailable = true;
                }
                else
                {
                    // Try appending the domain (e.g., mapache_hachyderm_io)
                    var sanitizedDomain = _mastodonDomain!.Replace(".", "_");
                    _userSlug = $"{sanitizedUser}_{sanitizedDomain}";

                    if (!LocalDbService.IsReservedUserSlug(_userSlug))
                    {
                        var existingUser2 = await DomainDb.GetUserBySlugAsync(_userSlug);
                        if (existingUser2 == null)
                        {
                            _slugAvailable = true;
                        }
                        else
                        {
                            // Both taken, leave blank
                            _userSlug = "";
                            _slugAvailable = false;
                        }
                    }
                    else
                    {
                        _userSlug = "";
                        _slugAvailable = false;
                    }
                }
            }
            else
            {
                // Reserved slug, try with domain appended
                var sanitizedDomain = _mastodonDomain!.Replace(".", "_");
                _userSlug = $"{sanitizedUser}_{sanitizedDomain}";

                if (!LocalDbService.IsReservedUserSlug(_userSlug))
                {
                    var existingUser = await DomainDb.GetUserBySlugAsync(_userSlug);
                    if (existingUser == null)
                    {
                        _slugAvailable = true;
                    }
                    else
                    {
                        _userSlug = "";
                        _slugAvailable = false;
                    }
                }
                else
                {
                    _userSlug = "";
                    _slugAvailable = false;
                }
            }
        }
        catch (Exception ex)
        {
            _message = $"Error during initialization: {ex.Message}";
            _isError = true;
        }
    }

    private async Task OnUserSlugChanged()
    {
        if (string.IsNullOrWhiteSpace(_userSlug))
        {
            _slugAvailable = false;
            return;
        }

        // Validate format
        if (!System.Text.RegularExpressions.Regex.IsMatch(_userSlug, @"^[a-zA-Z0-9_-]+$"))
        {
            _slugAvailable = false;
            return;
        }

        // Check if it's reserved
        if (LocalDbService.IsReservedUserSlug(_userSlug))
        {
            _slugAvailable = false;
            return;
        }

        _isCheckingSlug = true;
        await Task.Delay(300); // Debounce the check

        try
        {
            var user = await DomainDb.GetUserBySlugAsync(_userSlug);
            _slugAvailable = user == null;
        }
        catch
        {
            _slugAvailable = false;
        }
        finally
        {
            _isCheckingSlug = false;
        }
    }

    private async Task CreateProfile()
    {
        if (!_slugAvailable || string.IsNullOrWhiteSpace(_userSlug))
        {
            _message = "Please choose an available username";
            _isError = true;
            return;
        }

        _message = null;
        _isError = false;
        _isProcessing = true;

        try
        {
            var singleUserInstance = Configuration.GetValue<bool>("SingleUserInstance", false);
            var registrationOpenConfigured = Configuration.GetValue<bool>("RegistrationOpen", true);
            var canRegister = await DomainDb.CanAcceptRegistrationsAsync(singleUserInstance, registrationOpenConfigured);
            if (!canRegister)
            {
                _message = singleUserInstance
                    ? "This single-user instance has already been claimed."
                    : "Registration is currently closed.";
                _isError = true;
                return;
            }

            // Get domain
            var httpContext = HttpContextAccessor.HttpContext;
            if (httpContext == null)
            {
                _message = "Unable to determine your domain";
                _isError = true;
                return;
            }

            var domain = _domain?.Split(':')[0] ?? "localhost";

            bool isLinkedIn = _mastodonDomain == "linkedin.com";
            bool isGitHub   = _mastodonDomain == "github.com";
            bool isExternal = isLinkedIn || isGitHub;

            // Use the provider's full display name when available; fall back to username
            var displayName = isLinkedIn
                ? (_linkedInDisplayName ?? _mastodonUser ?? "LinkedIn User")
                : isGitHub
                    ? (_gitHubDisplayName ?? _mastodonUser ?? "GitHub User")
                    : $"{_mastodonUser} ({_mastodonDomain})";

            // Skip AP auto-population for non-Fediverse providers
            var (userId, slug) = await DomainDb.InitializeNewUserAsync(
                domain, _userSlug.ToLowerInvariant(), displayName, _mastodonUser, _mastodonDomain,
                autoPopulate: !isExternal);

            if (singleUserInstance)
            {
                var assignedAsRoot = await DomainDb.TrySetRootUserIdAsync(userId);
                if (!assignedAsRoot)
                {
                    var rootUserId = await DomainDb.GetRootUserIdAsync();
                    if (!rootUserId.HasValue || rootUserId.Value != userId)
                    {
                        await DomainDb.HardDeleteUserAsync(slug);
                        throw new ArgumentException("This single-user instance has already been claimed.");
                    }
                }
            }

            if (isLinkedIn)
            {
                // Use the profileUrl from the API response when available;
                // fall back to constructing it from the login name (which is sanitised full name)
                var profileUrl = !string.IsNullOrWhiteSpace(_linkedInProfileUrl)
                    ? _linkedInProfileUrl
                    : $"https://www.linkedin.com/in/{Uri.EscapeDataString(_mastodonUser!)}";

                var userDb = new FediProfile.Services.UserScopedDb(domain, slug, autoCreate: false);

                await userDb.UpsertSettingsAsync(
                    actorUsername: _linkedInDisplayName ?? _mastodonUser,
                    actorAvatarUrl: !string.IsNullOrWhiteSpace(_linkedInPicture) ? _linkedInPicture : null);

                await userDb.UpsertLinkAsync(
                    name: "LinkedIn",
                    url: profileUrl,
                    icon: "/assets/icons/linkedin.svg",
                    autoBoost: false,
                    hidden: false,
                    isActivityPub: false,
                    sortOrder: 0);

                await DomainDb.AddVerifiedUriAsync(slug, profileUrl);
            }
            else if (isGitHub)
            {
                // _mastodonUser is the GitHub login (username), profile URL is just github.com/{login}
                var profileUrl = $"https://github.com/{Uri.EscapeDataString(_mastodonUser!)}";

                var userDb = new FediProfile.Services.UserScopedDb(domain, slug, autoCreate: false);

                await userDb.UpsertSettingsAsync(
                    actorUsername: _gitHubDisplayName ?? _mastodonUser,
                    actorAvatarUrl: !string.IsNullOrWhiteSpace(_gitHubAvatarUrl) ? _gitHubAvatarUrl : null);

                await userDb.UpsertLinkAsync(
                    name: "GitHub",
                    url: profileUrl,
                    icon: "/assets/icons/github.svg",
                    autoBoost: false,
                    hidden: false,
                    isActivityPub: false,
                    sortOrder: 0);

                await DomainDb.AddVerifiedUriAsync(slug, profileUrl);
            }

            _message = $"Welcome, {slug}! Redirecting to your profile...";
            _isError = false;

            // Redirect to admin page
            await Task.Delay(500);
            var adminDest = "/admin/";
            if (!string.IsNullOrEmpty(_refParam)) adminDest += $"?ref={Uri.EscapeDataString(_refParam)}";
            NavigationManager.NavigateTo(adminDest);
        }
        catch (ArgumentException ex)
        {
            _message = $"Error: {ex.Message}";
            _isError = true;
        }
        catch (Exception ex)
        {
            _message = $"Error creating profile: {ex.Message}";
            _isError = true;
        }
        finally
        {
            _isProcessing = false;
        }
    }
}
