@page "/admin/root"
@using Microsoft.AspNetCore.Components
@using System.Security.Claims
@using System.Text.Json
@attribute [Authorize]
@layout FediProfile.Components.Layouts.MainLayout
@rendermode InteractiveServer

@inject DomainScopedDb DomainDb
@inject LocalDbFactory DbFactory
@inject AuthenticationStateProvider AuthStateProvider
@inject ILogger<AdminRoot> Logger
@inject NavigationManager Navigation
@inject LandingPageService LandingPageService
@inject IHttpContextAccessor HttpContextAccessor
@inject Microsoft.Extensions.Caching.Memory.IMemoryCache MemoryCache
@inject ProfileHtmlService ProfileHtml
@inject ActorService ActorService

<section class="admin-shell">
    <header class="admin-header">
        <div>
            <h1 class="admin-title">Root Administration</h1>
            <p class="admin-subtitle">Domain-level management for the instance owner.</p>
        </div>
        <div style="display:flex;gap:0.5rem;align-items:center">
            <a class="button button-ghost" href="/admin/">Back to Admin</a>
            <a class="button button-ghost" href="/logout">Logout</a>
        </div>
    </header>

    @if (!_isAuthorized || !_isRootUser)
    {
        <div class="admin-section">
            <article class="card">
                <div class="alert alert-error">
                    You do not have permission to access this page. Only the instance owner can manage domain settings.
                </div>
            </article>
        </div>
    }
    else
    {
        <!-- Tabs -->
        <div class="admin-tabs">
            <button class="admin-tab @(_activeTab == "settings" ? "admin-tab-active" : "")"
                    @onclick='() => SetTab("settings")'>Settings</button>
            <button class="admin-tab @(_activeTab == "users" ? "admin-tab-active" : "")"
                    @onclick='() => SetTab("users")'>Users</button>
            <button class="admin-tab @(_activeTab == "jobs" ? "admin-tab-active" : "")"
                    @onclick='() => SetTab("jobs")'>Job Queue</button>
            <button class="admin-tab @(_activeTab == "sql" ? "admin-tab-active" : "")"
                    @onclick='() => SetTab("sql")'>SQL</button>
            <button class="admin-tab @(_activeTab == "badges" ? "admin-tab-active" : "")"
                    @onclick='() => SetTab("badges")'>Badge Issuers</button>
        </div>

        @if (_activeTab == "settings")
        {
            <div class="admin-section">
                @if (!string.IsNullOrEmpty(_message))
                {
                    <div class="alert @(_isError ? "alert-error" : "alert-success")">
                        @_message
                    </div>
                }

                <article class="card">
                    <h2>Instance Settings</h2>
                    <p class="muted">Customize the name shown in the app header for this domain.</p>

                    <form @onsubmit="SaveInstanceSettings" class="admin-form">
                        <div class="form-group">
                            <label for="instanceName">Instance Name</label>
                            <input type="text" id="instanceName" @bind="_instanceName"
                                   placeholder="FediProfile" class="form-control" />
                            <small>Leave blank to fall back to the configured default name.</small>
                        </div>

                        <div class="form-group">
                            <label for="joinMastodonUrl">Join Mastodon URL</label>
                            <input type="url" id="joinMastodonUrl" @bind="_joinMastodonUrl"
                                   placeholder="https://joinmastodon.org" class="form-control" />
                            <small>The link shown to users who aren't on the Fediverse yet. Default: https://joinmastodon.org</small>
                        </div>

                        <button type="submit" class="button button-primary" disabled="@_isProcessing">
                            @(_isProcessing ? "Saving..." : "Save Instance Settings")
                        </button>
                    </form>
                </article>

                @if (!string.IsNullOrEmpty(_landingMessage))
                {
                    <div class="alert @(_landingIsError ? "alert-error" : "alert-success")">
                        @_landingMessage
                    </div>
                }

                <article class="card">
                    <h2>Landing Page Content</h2>
                    <p class="muted">Write markdown to generate a static domain landing page at <code>wwwroot/{domain}/landing.html</code>.</p>
                    <p class="muted">If this field is empty, the default shared <code>wwwroot/landing.html</code> is used.</p>

                    <form @onsubmit="SaveLandingPage" class="admin-form">
                        <div class="form-group">
                            <label for="landingMarkdown">Landing Markdown</label>
                            <textarea id="landingMarkdown"
                                      class="form-control sql-textarea"
                                      rows="16"
                                      placeholder="## Welcome\n\nIntroduce your instance and community here."
                                      @bind="_landingMarkdown"></textarea>
                            <small>Supports headings, links, lists, quotes, and code blocks.</small>
                        </div>

                        <div style="display:flex;gap:0.5rem;flex-wrap:wrap">
                            <button type="submit" class="button button-primary" disabled="@_isProcessing">
                                @(_isProcessing ? "Saving..." : "Save & Generate Static Landing")
                            </button>
                            <button type="button" class="button button-secondary" disabled="@_isProcessing" @onclick="ResetLandingPage">
                                @(_isProcessing ? "Resetting..." : "Restore Default Landing")
                            </button>
                            <a class="button button-ghost" href="/" target="_blank">Open Landing Page</a>
                        </div>
                    </form>
                </article>

                <article class="card">
                    <h2>Regenerate All Profiles</h2>
                    <p class="muted">Rebuild the static HTML and ActivityPub JSON for every user on this instance. Useful after template or settings changes.</p>

                    @if (!string.IsNullOrEmpty(_regenMessage))
                    {
                        <div class="alert @(_regenIsError ? "alert-error" : "alert-success")">
                            @_regenMessage
                        </div>
                    }

                    <button type="button" class="button button-primary" disabled="@_isProcessing" @onclick="RegenerateAllProfiles">
                        @(_isProcessing ? $"Regenerating... ({_regenProgress})" : "Regenerate All Profiles")
                    </button>
                </article>
            </div>
        }

        <!-- Users Tab -->
        @if (_activeTab == "users")
        {
            <div class="admin-section">
                <article class="card">
                    <h2>User Management</h2>
                    <p class="muted">Register new users into the system</p>

                    @if (!string.IsNullOrEmpty(_message))
                    {
                        <div class="alert @(_isError ? "alert-error" : "alert-success")">
                            @_message
                        </div>
                    }

                    <form @onsubmit="CreateUser" class="admin-form">
                        <div class="form-group">
                            <label for="userSlug">User Slug (username)</label>
                            <input type="text" id="userSlug" @bind="_newUserSlug" required
                                   placeholder="e.g., john-doe" pattern="[a-zA-Z0-9_-]+"
                                   class="form-control" />
                            <small>Only letters, numbers, hyphens, and underscores allowed</small>
                        </div>

                        <div class="form-group">
                            <label for="displayName">Display Name (optional)</label>
                            <input type="text" id="displayName" @bind="_newDisplayName"
                                   placeholder="e.g., John Doe" class="form-control" />
                        </div>

                        <button type="submit" class="button button-primary" disabled="@_isProcessing">
                            @(_isProcessing ? "Creating..." : "Create User")
                        </button>
                    </form>

                    <div class="admin-section">
                        <h3>Registered Users (@(_users?.Count ?? 0))</h3>
                        @if (_users == null)
                        {
                            <p>Loading users...</p>
                        }
                        else if (!_users.Any())
                        {
                            <p>No users registered yet.</p>
                        }
                        else
                        {
                            <table class="user-table">
                                <thead>
                                    <tr>
                                        <th>Slug</th>
                                        <th>Display Name</th>
                                        <th>Admin</th>
                                        <th>Created</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var user in _users)
                                    {
                                        <tr>
                                            <td><strong>@user.Slug</strong></td>
                                            <td>@(user.DisplayName ?? "-")</td>
                                            <td>
                                                @if (user.IsAdmin)
                                                {
                                                    <span class="job-status job-status-completed">Admin</span>
                                                }
                                                else
                                                {
                                                    <span class="job-status job-status-pending">User</span>
                                                }
                                            </td>
                                            <td>@user.CreatedUtc</td>
                                            <td>
                                                <a href="/@user.Slug" target="_blank" class="button button-small">View</a>
                                                <a href="/admin/?impersonate=@user.Slug" class="button button-small button-secondary">Edit</a>
                                                <button @onclick="() => ToggleAdmin(user)"
                                                        class="button button-small button-secondary"
                                                        disabled="@(_isProcessing || (_currentUserId.HasValue && _currentUserId.Value == user.Id && user.IsAdmin))"
                                                        title="@(_currentUserId.HasValue && _currentUserId.Value == user.Id && user.IsAdmin ? "You cannot remove your own admin access" : null)">
                                                    @(user.IsAdmin ? "Turn Off Admin" : "Turn Admin On")
                                                </button>
                                                @if (!IsOwnerUser(user.IsAdmin))
                                                {
                                                    <button @onclick="() => CreateUserDatabase(user.Slug)"
                                                            class="button button-small button-secondary"
                                                            disabled="@_isProcessing">
                                                        Init DB
                                                    </button>
                                                    @if (_confirmDeleteUserSlug == user.Slug)
                                                    {
                                                        <span class="confirm-inline">
                                                            <span>Delete <strong>@user.Slug</strong>?</span>
                                                            <button @onclick="() => DeleteUser(user.Slug)"
                                                                    class="button button-small button-danger"
                                                                    disabled="@_isProcessing">
                                                                Confirm
                                                            </button>
                                                            <button @onclick="() => _confirmDeleteUserSlug = null"
                                                                    class="button button-small button-ghost">
                                                                Cancel
                                                            </button>
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <button @onclick="() => _confirmDeleteUserSlug = user.Slug"
                                                                class="button button-small button-danger"
                                                                disabled="@_isProcessing">
                                                            Delete
                                                        </button>
                                                    }
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }

                        <div style="margin-top:1.5rem;border-top:1px solid var(--border, #e0e0e0);padding-top:1rem">
                            <h3>Maintenance</h3>
                            <p class="muted">Backfill verified URIs for all users by fetching their Mastodon ActivityPub actor.</p>
                            <button class="button button-secondary" @onclick="BackfillVerifiedUris" disabled="@_isProcessing">
                                @(_isProcessing ? "Running..." : "Backfill Verified URIs")
                            </button>
                            @if (_backfillResults != null)
                            {
                                <div style="margin-top:1rem">
                                    @foreach (var r in _backfillResults)
                                    {
                                        <div class="alert @(r.Success ? "alert-success" : "alert-error")" style="margin-bottom:0.25rem;padding:0.4rem 0.75rem;font-size:0.85rem">
                                            <strong>@r.UserSlug</strong>: @r.Message
                                        </div>
                                    }
                                </div>
                            }

                            <div style="margin-top:1.5rem;border-top:1px solid var(--border, #e0e0e0);padding-top:1rem">
                                <p class="muted">Fix links where users entered a handle (e.g. <code>@@user.bsky.social</code>) instead of a full URL for Bluesky, Matrix, or Telegram.</p>
                                <button class="button button-secondary" @onclick="FixHandleUrls" disabled="@_isProcessing">
                                    @(_isProcessing ? "Running..." : "Fix Handle URLs")
                                </button>
                                @if (_handleFixResults != null)
                                {
                                    <div style="margin-top:1rem">
                                        @foreach (var r in _handleFixResults)
                                        {
                                            <div class="alert @(r.IsError ? "alert-error" : "alert-success")" style="margin-bottom:0.25rem;padding:0.4rem 0.75rem;font-size:0.85rem">
                                                @r.Message
                                            </div>
                                        }
                                    </div>
                                }
                            </div>

                            <div style="margin-top:1.5rem;border-top:1px solid var(--border, #e0e0e0);padding-top:1rem">
                                <p class="muted">Scan all user databases for links whose URL does not start with <code>http</code>.</p>
                                <button class="button button-secondary" @onclick="AuditNonHttpUrls" disabled="@_isProcessing">
                                    @(_isProcessing ? "Scanning..." : "Audit Non-HTTP URLs")
                                </button>
                                @if (_auditResults != null)
                                {
                                    <div style="margin-top:1rem">
                                        @foreach (var r in _auditResults)
                                        {
                                            <div class="alert @(r.IsError ? "alert-error" : "alert-warning")" style="margin-bottom:0.25rem;padding:0.4rem 0.75rem;font-size:0.85rem">
                                                @r.Message
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </article>
            </div>
        }

        <!-- Jobs Tab -->
        @if (_activeTab == "jobs")
        {
            <div class="admin-section">
                <article class="card">
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem">
                        <div>
                            <h2 style="margin:0">Job Queue</h2>
                            <p class="muted" style="margin:0.25rem 0 0">Background ActivityPub job processing</p>
                        </div>
                        <div style="display:flex;gap:0.5rem;align-items:center">
                            <button class="button button-ghost button-small" @onclick="LoadJobs">
                                Refresh
                            </button>
                            @if (_confirmCleanJobs)
                            {
                                <span class="confirm-inline">
                                    <span>Clean old jobs?</span>
                                    <button class="button button-small button-danger" @onclick="ConfirmCleanJobs" disabled="@_isProcessing">
                                        @(_isProcessing ? "Cleaning..." : "Confirm")
                                    </button>
                                    <button class="button button-small button-ghost" @onclick="() => _confirmCleanJobs = false">
                                        Cancel
                                    </button>
                                </span>
                            }
                            else
                            {
                                <button class="button button-small button-danger" @onclick="() => _confirmCleanJobs = true" disabled="@_isProcessing"
                                        title="Remove old completed/failed jobs when there are more than 100">
                                    Clean Old Jobs
                                </button>
                            }
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(_cleanJobsMessage))
                    {
                        <div class="alert @(_cleanJobsIsError ? "alert-error" : "alert-success")" style="margin-bottom:1rem">
                            @_cleanJobsMessage
                        </div>
                    }

                    @if (_jobs == null)
                    {
                        <p>Loading jobs...</p>
                    }
                    else if (!_jobs.Any())
                    {
                        <p class="muted">No jobs in the queue yet.</p>
                    }
                    else
                    {
                        <!-- Status filter -->
                        <div style="display:flex;gap:0.5rem;margin-bottom:1rem;flex-wrap:wrap">
                            <button class="button button-small @(_jobFilter == null ? "button-primary" : "button-ghost")"
                                    @onclick="() => _jobFilter = null">All (@_jobs.Count)</button>
                            @foreach (var grp in _jobs.GroupBy(j => j.Status).OrderBy(g => g.Key))
                            {
                                <button class="button button-small @(_jobFilter == grp.Key ? "button-primary" : "button-ghost")"
                                        @onclick="@(() => _jobFilter = grp.Key)">@grp.Key (@grp.Count())</button>
                            }
                        </div>

                        <div class="jobs-table-wrap">
                            <table class="user-table jobs-table">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Type</th>
                                        <th>Status</th>
                                        <th>Actor</th>
                                        <th>Retries</th>
                                        <th>Created</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var job in FilteredJobs)
                                    {
                                        <tr class="@GetJobRowClass(job) @(_selectedJob?.Id == job.Id ? "job-row-selected" : "")" @onclick="() => ToggleJob(job)" style="cursor:pointer">
                                            <td>@job.Id</td>
                                            <td><span class="job-type-badge">@job.JobType</span></td>
                                            <td><span class="job-status job-status-@job.Status">@job.Status</span></td>
                                            <td class="job-actor-cell" title="@job.ActorUri">@TruncateActor(job.ActorUri)</td>
                                            <td>@job.CurrentRetry/@job.MaxRetries</td>
                                            <td class="job-date-cell">@job.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                            <td>
                                                <button class="button button-small button-ghost" @onclick="() => ToggleJob(job)" @onclick:stopPropagation="true">
                                                    @(_selectedJob?.Id == job.Id ? "Hide" : "Details")
                                                </button>
                                                @if (job.Status == "failed")
                                                {
                                                    <button class="button button-small button-secondary" @onclick="() => RetryJob(job.Id)" @onclick:stopPropagation="true"
                                                            disabled="@_isProcessing">
                                                        Retry
                                                    </button>
                                                }
                                            </td>
                                        </tr>
                                        @if (_selectedJob?.Id == job.Id)
                                        {
                                            <tr class="job-detail-inline-row">
                                                <td colspan="7" style="padding:0">
                                                    <div class="job-detail-inline" @onclick:stopPropagation="true">
                                                        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.75rem">
                                                            <h3 style="margin:0;font-size:1rem">Job #@_selectedJob.Id — @_selectedJob.JobType</h3>
                                                            <button class="button button-ghost button-small" @onclick="() => _selectedJob = null">Close</button>
                                                        </div>

                                                        <div class="job-detail-grid">
                                                            <div class="job-detail-row">
                                                                <span class="job-detail-label">Status</span>
                                                                <span class="job-status job-status-@_selectedJob.Status">@_selectedJob.Status</span>
                                                            </div>
                                                            <div class="job-detail-row">
                                                                <span class="job-detail-label">Actor URI</span>
                                                                <span>@(_selectedJob.ActorUri ?? "—")</span>
                                                            </div>
                                                            <div class="job-detail-row">
                                                                <span class="job-detail-label">Created</span>
                                                                <span>@_selectedJob.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</span>
                                                            </div>
                                                            <div class="job-detail-row">
                                                                <span class="job-detail-label">Scheduled For</span>
                                                                <span>@_selectedJob.ScheduledFor.ToString("yyyy-MM-dd HH:mm:ss")</span>
                                                            </div>
                                                            <div class="job-detail-row">
                                                                <span class="job-detail-label">Started</span>
                                                                <span>@(_selectedJob.StartedAt?.ToString("yyyy-MM-dd HH:mm:ss") ?? "—")</span>
                                                            </div>
                                                            <div class="job-detail-row">
                                                                <span class="job-detail-label">Completed</span>
                                                                <span>@(_selectedJob.CompletedAt?.ToString("yyyy-MM-dd HH:mm:ss") ?? "—")</span>
                                                            </div>
                                                            <div class="job-detail-row">
                                                                <span class="job-detail-label">Retries</span>
                                                                <span>@_selectedJob.CurrentRetry / @_selectedJob.MaxRetries</span>
                                                            </div>
                                                            <div class="job-detail-row">
                                                                <span class="job-detail-label">Created By</span>
                                                                <span>@(_selectedJob.CreatedBy ?? "—")</span>
                                                            </div>
                                                            <div class="job-detail-row">
                                                                <span class="job-detail-label">Notes</span>
                                                                <span>@(_selectedJob.Notes ?? "—")</span>
                                                            </div>
                                                            @if (!string.IsNullOrEmpty(_selectedJob.LastError))
                                                            {
                                                                <div class="job-detail-row">
                                                                    <span class="job-detail-label">Last Error</span>
                                                                    <span class="job-error-text">@_selectedJob.LastError</span>
                                                                </div>
                                                            }
                                                        </div>

                                                        @if (_selectedJob.Status == "failed")
                                                        {
                                                            <div style="margin-top:1rem">
                                                                <button class="button button-secondary" @onclick="() => RetryJob(_selectedJob.Id)" disabled="@_isProcessing">
                                                                    Retry This Job
                                                                </button>
                                                            </div>
                                                        }

                                                        <!-- Payload -->
                                                        <div style="margin-top:1.5rem">
                                                            <h4 style="margin-bottom:0.5rem">Payload</h4>
                                                            @if (string.IsNullOrEmpty(_selectedJob.Payload))
                                                            {
                                                                <p class="muted">No payload.</p>
                                                            }
                                                            else
                                                            {
                                                                <pre class="job-payload-pre">@FormatJson(_selectedJob.Payload)</pre>
                                                            }
                                                        </div>

                                                        <!-- Logs -->
                                                        <div style="margin-top:1.5rem">
                                                            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.5rem">
                                                                <h4 style="margin:0">Logs</h4>
                                                                <button class="button button-ghost button-small" @onclick="LoadSelectedJobLogs">Refresh</button>
                                                            </div>
                                                            @if (_selectedJobLogs == null)
                                                            {
                                                                <p>Loading logs...</p>
                                                            }
                                                            else if (!_selectedJobLogs.Any())
                                                            {
                                                                <p class="muted">No log entries.</p>
                                                            }
                                                            else
                                                            {
                                                                <div class="job-logs-list">
                                                                    @foreach (var log in _selectedJobLogs)
                                                                    {
                                                                        <div class="job-log-entry @(log.Message.StartsWith("FAILED") || log.Message.StartsWith("RETRY") ? "job-log-error" : "")">
                                                                            <span class="job-log-time">@log.CreatedAt.ToString("HH:mm:ss")</span>
                                                                            <span class="job-log-msg">@log.Message</span>
                                                                        </div>
                                                                    }
                                                                </div>
                                                            }
                                                        </div>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </article>
            </div>
        }
        <!-- SQL Tab -->
        @if (_activeTab == "sql")
        {
            <div class="admin-section">
                <article class="card">
                    <h2>SQL Query</h2>
                    <p class="muted">Execute SQL queries against any database in the data directory.</p>

                    <div class="admin-form">
                        <div class="form-group">
                            <label for="dbFilter">Filter</label>
                            <div style="display:flex;gap:0.5rem;align-items:center">
                                <input type="text" id="dbFilter" class="form-control" @bind="_dbFilter"
                                       placeholder="e.g. mydomain*" style="flex:1" />
                                <button class="button button-small button-secondary" @onclick="LoadAvailableDbs">Apply</button>
                                <button class="button button-small button-ghost" @onclick="ClearDbFilter">All</button>
                            </div>
                            <small>Glob-style filter for database names. Default: <code>@(_defaultDbFilter)*</code></small>
                        </div>

                        <div class="form-group">
                            <label for="dbSelect">Database</label>
                            <select id="dbSelect" class="form-control" @bind="_selectedDb">
                                <option value="">— Select a database —</option>
                                @if (_filteredDbs != null)
                                {
                                    @foreach (var db in _filteredDbs)
                                    {
                                        <option value="@db">@Path.GetFileName(db)</option>
                                    }
                                }
                            </select>
                        </div>

                        <!-- Common Queries -->
                        <div class="form-group">
                            <label>Common Queries</label>
                            <div class="common-queries-buttons">
                                <button class="button button-small button-ghost" @onclick="() => SetSqlQuery(_queryShowTables)"
                                        title="List all tables in the database">
                                    Show Tables
                                </button>
                                <button class="button button-small button-ghost" @onclick="() => SetSqlQuery(_queryTableNames)"
                                        title="List table names only">
                                    Table Names
                                </button>
                                <button class="button button-small button-ghost" @onclick="() => SetSqlQuery(_queryTableSchema)"
                                        title="Get schema for a specific table (replace &lt;table_name&gt; with actual table name)">
                                    Table Schema
                                </button>
                                <button class="button button-small button-ghost" @onclick="() => SetSqlQuery(_queryCreateStatement)"
                                        title="Get CREATE TABLE statement">
                                    Create Statement
                                </button>
                                <button class="button button-small button-ghost" @onclick="() => SetSqlQuery(_queryMigrateRecentPostsMedia)"
                                        title="Add MediaUrls column to RecentPosts (for existing user databases)">
                                    Migrate Recent Media
                                </button>
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="sqlQuery">SQL</label>
                            <textarea id="sqlQuery" class="form-control sql-textarea" @bind="_sqlQuery"
                                      rows="6" placeholder="SELECT * FROM sqlite_master WHERE type='table';"></textarea>
                        </div>

                        <div style="display:flex;gap:0.5rem;flex-wrap:wrap">
                            <button class="button button-primary" @onclick="ExecuteSql" disabled="@_isSqlRunning">
                                @(_isSqlRunning ? "Running..." : "Execute")
                            </button>
                            <button class="button button-secondary" @onclick="ExecuteSqlOnAllDbs" disabled="@_isSqlRunning"
                                    title="Run this query against every database in the data directory">
                                @(_isSqlRunning ? "Running..." : "Execute on All DBs")
                            </button>
                            <button class="button button-ghost" @onclick="ClearSqlResults">Clear</button>
                            @if (_confirmDeleteDb && !string.IsNullOrEmpty(_selectedDb))
                            {
                                <span class="confirm-inline">
                                    <span>Delete <strong>@Path.GetFileName(_selectedDb)</strong>?</span>
                                    <button class="button button-small button-danger" @onclick="ConfirmDeleteSelectedDb"
                                            disabled="@_isSqlRunning">
                                        Confirm
                                    </button>
                                    <button class="button button-small button-ghost" @onclick="() => _confirmDeleteDb = false">
                                        Cancel
                                    </button>
                                </span>
                            }
                            else
                            {
                                <button class="button button-small button-danger" @onclick="() => _confirmDeleteDb = true"
                                        disabled="@(_isSqlRunning || string.IsNullOrEmpty(_selectedDb))"
                                        title="Permanently delete the selected database file">
                                    Delete DB
                                </button>
                            }
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(_sqlError))
                    {
                        <div class="alert alert-error" style="margin-top:1rem">@_sqlError</div>
                    }

                    @if (!string.IsNullOrEmpty(_sqlSuccess))
                    {
                        <div class="alert alert-success" style="margin-top:1rem">@_sqlSuccess</div>
                    }

                    @if (_sqlAllDbResults != null && _sqlAllDbResults.Count > 0)
                    {
                        <div style="margin-top:1rem">
                            <h3 style="margin-bottom:0.5rem">Results per database</h3>
                            @foreach (var r in _sqlAllDbResults)
                            {
                                <div class="alert @(r.IsError ? "alert-error" : "alert-success")" style="margin-bottom:0.25rem;padding:0.4rem 0.75rem;font-size:0.85rem">
                                    <strong>@r.DbName</strong>: @r.Message
                                </div>
                            }
                        </div>
                    }

                    @if (_sqlColumns != null && _sqlColumns.Count > 0)
                    {
                        <div class="sql-results-wrap" style="margin-top:1rem">
                            <table class="user-table sql-results-table">
                                <thead>
                                    <tr>
                                        @foreach (var col in _sqlColumns)
                                        {
                                            <th>@col</th>
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var row in _sqlRows!)
                                    {
                                        <tr>
                                            @foreach (var col in _sqlColumns)
                                            {
                                                var value = (row.ContainsKey(col) ? row[col]?.ToString() ?? "NULL" : "");
                                                <td title="@value" class="sql-cell">@TruncateForDisplay(value, 60)</td>
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                            <p class="muted" style="margin-top:0.5rem;font-size:0.82rem">@_sqlRows!.Count row(s) returned</p>
                        </div>
                    }
                </article>
            </div>
        }
        <!-- Badge Issuers Tab -->
        @if (_activeTab == "badges")
        {
            <div class="admin-section">
                <article class="card">
                    <h2>Badge Issuers</h2>
                    <p class="muted">Add relay bot actor URLs to sync badge announcements from their outbox.</p>

                    @if (!string.IsNullOrEmpty(_badgeMessage))
                    {
                        <div class="alert @(_badgeIsError ? "alert-error" : "alert-success")">
                            @_badgeMessage
                        </div>
                    }

                    <form @onsubmit="AddBadgeIssuer" class="admin-form">
                        <div class="form-group">
                            <label for="issuerUrl">Actor URL</label>
                            <input type="url" id="issuerUrl" @bind="_newIssuerUrl" required
                                   placeholder="e.g., https://badgefed.org/actors/badgefed.org/_relaybot"
                                   class="form-control" />
                            <small>The ActivityPub actor URL of the badge issuer or relay bot.</small>
                        </div>
                        <button type="submit" class="button button-primary" disabled="@_isProcessing">
                            @(_isProcessing ? "Adding..." : "Add Badge Issuer")
                        </button>
                    </form>

                    <div class="admin-section" style="margin-top:1.5rem">
                        <h3>Registered Badge Issuers (@(_badgeIssuers?.Count ?? 0))</h3>
                        @if (_badgeIssuers == null)
                        {
                            <p>Loading...</p>
                        }
                        else if (!_badgeIssuers.Any())
                        {
                            <p class="muted">No badge issuers registered yet.</p>
                        }
                        else
                        {
                            <table class="user-table">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Name</th>
                                        <th>Actor URL</th>
                                        <th>Created</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var issuer in _badgeIssuers)
                                    {
                                        <tr>
                                            <td>@issuer.Id</td>
                                            <td>@issuer.Name</td>
                                            <td style="max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="@issuer.ActorUrl">
                                                <a href="@issuer.ActorUrl" target="_blank">@issuer.ActorUrl</a>
                                            </td>
                                            <td>@issuer.CreatedUtc</td>
                                            <td>
                                                <button class="button button-small button-secondary"
                                                        @onclick="() => SyncBadgeIssuer(issuer)"
                                                        disabled="@_isProcessing">
                                                    @(_syncingIssuerId == issuer.Id ? "Syncing..." : "Sync Outbox")
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                </article>
            </div>
        }
    }
</section>

<style>
