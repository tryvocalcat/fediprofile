    private void LoadAvailableDbs()
    {
        try
        {
            var dbDir = Environment.GetEnvironmentVariable("DB_DATA");
            if (string.IsNullOrEmpty(dbDir))
                dbDir = Path.Combine(Directory.GetCurrentDirectory(), "App_Data");

            if (Directory.Exists(dbDir))
            {
                _availableDbs = Directory.GetFiles(dbDir, "*.db")
                    .OrderBy(f => f)
                    .ToList();
            }
            else
            {
                _availableDbs = new List<string>();
            }

            // Set default filter to domain* on first load
            if (string.IsNullOrEmpty(_defaultDbFilter))
            {
                _defaultDbFilter = DomainDb.GetDomain() ?? "localhost";
                if (string.IsNullOrEmpty(_dbFilter))
                    _dbFilter = _defaultDbFilter;
            }

            ApplyDbFilter();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error listing databases");
            _availableDbs = new List<string>();
            _filteredDbs = new List<string>();
        }
    }

    private void ApplyDbFilter()
    {
        if (_availableDbs == null)
        {
            _filteredDbs = new List<string>();
            return;
        }

        if (string.IsNullOrWhiteSpace(_dbFilter))
        {
            _filteredDbs = _availableDbs;
            return;
        }

        var filter = _dbFilter.Trim().ToLowerInvariant();
        _filteredDbs = _availableDbs
            .Where(db =>
            {
                var name = Path.GetFileName(db).ToLowerInvariant();
                if (filter.Contains('*'))
                {
                    // Simple glob: split on * and check starts/ends
                    var parts = filter.Split('*');
                    if (parts.Length == 2)
                        return name.StartsWith(parts[0]) && name.EndsWith(parts[1]);
                    // Fallback: contains each part in order
                    int pos = 0;
                    foreach (var part in parts)
                    {
                        if (string.IsNullOrEmpty(part)) continue;
                        var idx = name.IndexOf(part, pos);
                        if (idx < 0) return false;
                        pos = idx + part.Length;
                    }
                    return true;
                }
                return name.Contains(filter);
            })
            .ToList();
    }

    private void ClearDbFilter()
    {
        _dbFilter = null;
        ApplyDbFilter();
    }

