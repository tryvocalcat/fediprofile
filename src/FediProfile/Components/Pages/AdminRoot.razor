</style>

@code {
    private bool _isAuthorized;
    private bool _isRootUser;
    private int? _currentUserId;
    private string? _currentUserSlug;
    private string _activeTab = "settings";
    private bool _isProcessing;
    private string? _instanceName;
    private string? _joinMastodonUrl;
    private string? _landingMarkdown;
    private string? _landingMessage;
    private bool _landingIsError;
    private string? _regenMessage;
    private bool _regenIsError;
    private string _regenProgress = "";

    // Confirmation state
    private string? _confirmDeleteUserSlug;
    private bool _confirmDeleteDb;
    private bool _confirmCleanJobs;

    // Users tab
    private string? _newUserSlug;
    private string? _newDisplayName;
    private string? _message;
    private bool _isError;
    private List<(int Id, string Slug, string? DisplayName, string CreatedUtc, bool IsAdmin)>? _users;

    // Jobs tab
    private List<SimpleJob>? _jobs;
    private string? _jobFilter;
    private SimpleJob? _selectedJob;
    private List<SimpleJobLog>? _selectedJobLogs;

    private IEnumerable<SimpleJob> FilteredJobs =>
        _jobFilter == null ? (_jobs ?? Enumerable.Empty<SimpleJob>())
                           : (_jobs ?? Enumerable.Empty<SimpleJob>()).Where(j => j.Status == _jobFilter);

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        var mastodonUser = state.User.FindFirst(ClaimTypes.Name)?.Value;
        var mastodonHost = state.User.FindFirst("urn:mastodon:hostname")?.Value;

        _isAuthorized = false;
        _isRootUser = false;

        if (!string.IsNullOrWhiteSpace(mastodonUser) && !string.IsNullOrWhiteSpace(mastodonHost))
        {
            var dbUser = await DomainDb.GetUserByMastodonAsync(mastodonUser, mastodonHost);
            if (dbUser.HasValue)
            {
                _currentUserId = dbUser.Value.Id;
                _currentUserSlug = dbUser.Value.Slug;
                _isAuthorized = true;
                _isRootUser = await DomainDb.IsRootUserAsync(dbUser.Value.Id);
            }
        }

        if (_isRootUser)
        {
            await LoadInstanceSettings();
            await LoadLandingSettings();
            await LoadUsers();
            LoadJobs();
        }
    }

    private void SetTab(string tab)
    {
        _activeTab = tab;
        if (tab == "settings") _ = LoadLandingSettings();
        if (tab == "jobs") LoadJobs();
        if (tab == "sql") LoadAvailableDbs();
        if (tab == "badges") _ = LoadBadgeIssuers();
    }

    private bool IsOwnerUser(bool isAdmin)
    {
        return isAdmin;
    }

    private async Task LoadInstanceSettings()
    {
        _instanceName = await DomainDb.GetStoredInstanceNameAsync();
        _joinMastodonUrl = await DomainDb.GetJoinMastodonUrlAsync();
    }

    private async Task SaveInstanceSettings()
    {
        _message = null;
        _isError = false;
        _isProcessing = true;

        try
        {
            var requestedName = string.IsNullOrWhiteSpace(_instanceName) ? null : _instanceName.Trim();
            await DomainDb.SetInstanceNameAsync(requestedName);
            await DomainDb.SetJoinMastodonUrlAsync(_joinMastodonUrl);
            await LoadInstanceSettings();
            _message = requestedName == null
                ? "Instance name cleared. The UI will use the configured default name."
                : $"Instance name saved as '{requestedName}'.";
        }
        catch (Exception ex)
        {
            _message = $"Error saving instance settings: {ex.Message}";
            _isError = true;
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private async Task LoadLandingSettings()
    {
        _landingMarkdown = await DomainDb.GetLandingMarkdownAsync();
    }

    private async Task SaveLandingPage()
    {
        _landingMessage = null;
        _landingIsError = false;
        _isProcessing = true;

        try
        {
            var host = ResolveCurrentHostForLanding();
            var markdown = string.IsNullOrWhiteSpace(_landingMarkdown) ? null : _landingMarkdown.Trim();

            await DomainDb.SetLandingMarkdownAsync(markdown);

            if (markdown == null)
            {
                await LandingPageService.DeleteDomainLandingAsync(host);
                _landingMessage = "Landing markdown cleared. Restored default shared landing page.";
            }
            else
            {
                var instanceName = await DomainDb.GetInstanceNameAsync();
                await LandingPageService.GenerateDomainLandingAsync(host, instanceName, markdown);
                _landingMessage = "Landing page saved and static file regenerated for this domain.";
            }

            InvalidateLandingCache(host);
            await LoadLandingSettings();
        }
        catch (Exception ex)
        {
            _landingMessage = $"Error saving landing page: {ex.Message}";
            _landingIsError = true;
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private async Task ResetLandingPage()
    {
        _landingMessage = null;
        _landingIsError = false;
        _isProcessing = true;

        try
        {
            var host = ResolveCurrentHostForLanding();
            await DomainDb.SetLandingMarkdownAsync(null);
            await LandingPageService.DeleteDomainLandingAsync(host);
            _landingMarkdown = null;
            InvalidateLandingCache(host);

            _landingMessage = "Landing page reset. Default shared landing page is now active.";
        }
        catch (Exception ex)
        {
            _landingMessage = $"Error resetting landing page: {ex.Message}";
            _landingIsError = true;
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private async Task RegenerateAllProfiles()
    {
        _regenMessage = null;
        _regenIsError = false;
        _isProcessing = true;
        _regenProgress = "";
        StateHasChanged();

        try
        {
            var domain = DomainDb.GetDomain();
            var httpContext = HttpContextAccessor.HttpContext;
            var scheme = httpContext?.Request.Scheme ?? "https";
            var fullDomain = httpContext?.Request.Host.ToString() ?? domain;
            var baseDomain = $"{scheme}://{fullDomain}";
            var joinUrl = await DomainDb.GetJoinMastodonUrlAsync();

            var users = await DomainDb.GetAllUsersAsync();
            var total = users.Count;
            var done = 0;
            var failed = 0;

            foreach (var user in users)
            {
                try
                {
                    var userDb = DbFactory.GetInstance(domain, user.Slug);
                    var verifiedUris = (await DomainDb.GetVerifiedUrisAsync(user.Slug)).Select(v => v.Uri).ToList();
                    await ProfileHtml.GenerateAsync(userDb, user.Slug, baseDomain, fullDomain, joinUrl);
                    await ActorService.GenerateActorJsonAsync(userDb, user.Slug, baseDomain, fullDomain, verifiedUris);
                }
                catch (Exception ex)
                {
                    Logger.LogWarning(ex, "Failed to regenerate profile for {User}", user.Slug);
                    failed++;
                }

                done++;
                _regenProgress = $"{done}/{total}";
                StateHasChanged();
            }

            _regenMessage = failed == 0
                ? $"Successfully regenerated {total} profile(s)."
                : $"Regenerated {total - failed}/{total} profiles. {failed} failed (check logs).";
            _regenIsError = failed > 0;
        }
        catch (Exception ex)
        {
            _regenMessage = $"Error: {ex.Message}";
            _regenIsError = true;
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private string ResolveCurrentHostForLanding()
    {
        var request = HttpContextAccessor.HttpContext?.Request;
        if (request != null)
        {
            return LandingPageService.ResolveHost(request);
        }

        return DomainDb.GetDomain() ?? "localhost";
    }

    private void InvalidateLandingCache(string host)
    {
        MemoryCache.Remove(LandingPageService.BuildCacheKey(host));
    }

    // ===== Users =====

    private async Task LoadUsers()
    {
        try
        {
            _users = await DomainDb.GetAllUsersWithAdminAsync();
        }
        catch (Exception ex)
        {
            _message = $"Error loading users: {ex.Message}";
            _isError = true;
        }
    }

    private async Task ToggleAdmin((int Id, string Slug, string? DisplayName, string CreatedUtc, bool IsAdmin) user)
    {
        _message = null;
        _isError = false;
        _isProcessing = true;

        try
        {
            if (!_currentUserId.HasValue)
            {
                _message = "Unable to determine current user identity.";
                _isError = true;
                return;
            }

            var makeAdmin = !user.IsAdmin;
            var result = await DomainDb.SetUserAdminAsync(user.Id, makeAdmin, _currentUserId.Value);
            if (!result.Success)
            {
                _message = result.Error ?? "Unable to update admin status.";
                _isError = true;
                return;
            }

            _message = makeAdmin
                ? $"User '{user.Slug}' is now an admin."
                : $"User '{user.Slug}' is no longer an admin.";
            _isError = false;
            await LoadUsers();
        }
        catch (Exception ex)
        {
            _message = $"Error updating admin status: {ex.Message}";
            _isError = true;
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private async Task CreateUser()
    {
        _message = null;
        _isError = false;
        _isProcessing = true;

        try
        {
            if (string.IsNullOrWhiteSpace(_newUserSlug))
            {
                _message = "User slug is required";
                _isError = true;
                return;
            }

            if (!System.Text.RegularExpressions.Regex.IsMatch(_newUserSlug, @"^[a-zA-Z0-9_-]+$"))
            {
                _message = "Invalid slug format. Only letters, numbers, hyphens, and underscores allowed.";
                _isError = true;
                return;
            }

            var (id, slug) = await DomainDb.CreateOrGetUserAsync(_newUserSlug.Trim().ToLowerInvariant(), _newDisplayName?.Trim());
            _message = $"User '{slug}' created successfully!";
            _isError = false;
            _newUserSlug = null;
            _newDisplayName = null;
            await LoadUsers();
        }
        catch (Exception ex)
        {
            _message = $"Error creating user: {ex.Message}";
            _isError = true;
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private async Task CreateUserDatabase(string userSlug)
    {
        _message = null;
        _isError = false;
        _isProcessing = true;

        try
        {
            var userDb = new UserScopedDb(DomainDb.GetDomain() ?? "localhost", userSlug, autoCreate: true);
            await userDb.GetSettingsAsync();

            var (existingPubKey, _) = await userDb.GetActorKeysAsync();
            if (string.IsNullOrEmpty(existingPubKey))
            {
                var keyPair = await CryptoService.GenerateKeyPairAsync();
                await userDb.SetActorKeysAsync(keyPair.PublicKeyPem, keyPair.PrivateKeyPem);
            }

            _message = $"Database for user '{userSlug}' initialized successfully!";
            _isError = false;
        }
        catch (Exception ex)
        {
            _message = $"Error creating database: {ex.Message}";
            _isError = true;
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private async Task DeleteUser(string userSlug)
    {
        _message = null;
        _isError = false;
        _isProcessing = true;
        _confirmDeleteUserSlug = null;

        try
        {
            var success = await DomainDb.HardDeleteUserAsync(userSlug);
            if (success)
            {
                _message = $"User '{userSlug}' has been hard-deleted (user row, following entries, and database file removed).";
                _isError = false;
                await LoadUsers();
            }
            else
            {
                _message = $"User '{userSlug}' not found.";
                _isError = true;
            }
        }
        catch (Exception ex)
        {
            _message = $"Error deleting user: {ex.Message}";
            _isError = true;
        }
        finally
        {
            _isProcessing = false;
        }
    }

    // ===== Backfill =====

    private List<(string UserSlug, bool Success, string Message)>? _backfillResults;

    private async Task BackfillVerifiedUris()
    {
        _message = null;
        _isError = false;
        _isProcessing = true;
        _backfillResults = null;
        StateHasChanged();

        try
        {
            _backfillResults = await DomainDb.BackfillVerifiedUrisAsync();
            var ok = _backfillResults.Count(r => r.Success);
            var fail = _backfillResults.Count(r => !r.Success);
            _message = $"Backfill complete: {ok} succeeded, {fail} failed out of {_backfillResults.Count} user(s).";
            _isError = fail > 0;
        }
        catch (Exception ex)
        {
            _message = $"Backfill error: {ex.Message}";
            _isError = true;
        }
        finally
        {
            _isProcessing = false;
        }
    }

    // ===== Fix Handle URLs =====

    private static readonly Dictionary<string, (string HandlePrefix, string UrlTemplate, string PlatformName)> _urlFixRules = new()
    {
        ["/assets/icons/bluesky.svg"]  = ("@", "https://bsky.app/profile/{0}", "Bluesky"),
        ["/assets/icons/matrix.svg"]   = ("@", "https://matrix.to/#/{0}",      "Matrix"),
        ["/assets/icons/telegram.svg"] = ("@", "https://t.me/{0}",             "Telegram"),
    };

    // Also match by link name (case-insensitive) when icon doesn't match
    private static readonly Dictionary<string, (string HandlePrefix, string UrlTemplate, string PlatformName)> _nameFixRules = new(StringComparer.OrdinalIgnoreCase)
    {
        ["Bluesky"]  = ("@", "https://bsky.app/profile/{0}", "Bluesky"),
        ["Matrix"]   = ("@", "https://matrix.to/#/{0}",      "Matrix"),
        ["Telegram"] = ("@", "https://t.me/{0}",             "Telegram"),
    };

    private static bool IsWebfingerHandle(string input)
    {
        if (!input.StartsWith("@")) return false;
        var withoutLeadingAt = input.Substring(1);
        var atIdx = withoutLeadingAt.IndexOf('@');
        return atIdx > 0 && atIdx < withoutLeadingAt.Length - 1 && withoutLeadingAt.Substring(atIdx + 1).Contains('.');
    }

    private static async Task<(string? ProfileUrl, string? ActorUri)> ResolveWebfingerAsync(string handle)
    {
        var withoutLeadingAt = handle.TrimStart('@');
        var atIdx = withoutLeadingAt.IndexOf('@');
        if (atIdx <= 0) return (null, null);
        var domain = withoutLeadingAt.Substring(atIdx + 1);

        var webfingerUrl = $"https://{domain}/.well-known/webfinger?resource=acct:{withoutLeadingAt}";

        using var http = new HttpClient { Timeout = TimeSpan.FromSeconds(10) };
        http.DefaultRequestHeaders.Add("Accept", "application/jrd+json, application/json");
        var resp = await http.GetAsync(webfingerUrl);
        resp.EnsureSuccessStatusCode();

        var json = await resp.Content.ReadAsStringAsync();
        using var doc = JsonDocument.Parse(json);

        string? profileUrl = null;
        string? actorUri = null;

        if (doc.RootElement.TryGetProperty("links", out var links))
        {
            foreach (var link in links.EnumerateArray())
            {
                var rel = link.TryGetProperty("rel", out var r) ? r.GetString() : null;
                var type = link.TryGetProperty("type", out var t) ? t.GetString() : null;
                var href = link.TryGetProperty("href", out var h) ? h.GetString() : null;
                if (string.IsNullOrEmpty(href)) continue;

                if (rel == "self" && type != null && type.Contains("activity"))
                    actorUri = href;
                else if (rel == "http://webfinger.net/rel/profile-page")
                    profileUrl = href;
            }
        }

        return (profileUrl ?? actorUri, actorUri);
    }

    private List<(string Message, bool IsError)>? _handleFixResults;

    private async Task FixHandleUrls()
    {
        _isProcessing = true;
        _handleFixResults = new();
        StateHasChanged();

        try
        {
            var users = await DomainDb.GetAllUsersAsync();
            var domain = DomainDb.GetDomain() ?? "localhost";
            int totalFixed = 0;

            foreach (var user in users)
            {
                try
                {
                    var userDb = new UserScopedDb(domain, user.Slug, autoCreate: false);
                    var links = await userDb.GetLinksAsync();
                    int userFixed = 0;

                    foreach (var link in links)
                    {
                        if (string.IsNullOrWhiteSpace(link.Url)) continue;
                        var url = link.Url.Trim();

                        // Skip already-valid URLs
                        if (url.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
                            url.StartsWith("https://", StringComparison.OrdinalIgnoreCase))
                            continue;

                        // Check for @user@domain webfinger handles first
                        if (IsWebfingerHandle(url))
                        {
                            try
                            {
                                var (wfProfileUrl, wfActorUri) = await ResolveWebfingerAsync(url);
                                if (!string.IsNullOrEmpty(wfProfileUrl))
                                {
                                    bool isAP = !string.IsNullOrEmpty(wfActorUri);
                                    await userDb.UpdateLinkAsync(
                                        link.Id, link.Name, wfProfileUrl, link.Icon, link.Description,
                                        link.AutoBoost, link.Category, link.Hidden, isAP || link.IsActivityPub,
                                        wfActorUri ?? link.ActorAPUri);

                                    var apNote = isAP ? " (ActivityPub ✓)" : "";
                                    _handleFixResults.Add(($"{user.Slug}: Resolved WebFinger \"{link.Name}\" — {url} → {wfProfileUrl}{apNote}", false));
                                    userFixed++;
                                    continue;
                                }
                            }
                            catch (Exception ex)
                            {
                                _handleFixResults.Add(($"{user.Slug}: WebFinger failed for \"{link.Name}\" ({url}) — {ex.Message}", true));
                                continue;
                            }
                        }

                        // Check if the icon or name matches a known platform
                        (string HandlePrefix, string UrlTemplate, string PlatformName)? matchedRule = null;
                        if (!string.IsNullOrEmpty(link.Icon) && _urlFixRules.TryGetValue(link.Icon, out var iconRule))
                            matchedRule = iconRule;
                        else if (!string.IsNullOrEmpty(link.Name) && _nameFixRules.TryGetValue(link.Name.Trim(), out var nameRule))
                            matchedRule = nameRule;

                        if (matchedRule is { } rule)
                        {
                            if (url.StartsWith(rule.HandlePrefix))
                            {
                                var handle = url.TrimStart('@', '#');
                                var corrected = string.Format(rule.UrlTemplate, handle);

                                await userDb.UpdateLinkAsync(
                                    link.Id, link.Name, corrected, link.Icon, link.Description,
                                    link.AutoBoost, link.Category, link.Hidden, link.IsActivityPub, link.ActorAPUri);

                                _handleFixResults.Add(($"{user.Slug}: Fixed {rule.PlatformName} link \"{link.Name}\" — {url} → {corrected}", false));
                                userFixed++;
                            }
                        }
                    }

                    totalFixed += userFixed;
                }
                catch (Exception ex)
                {
                    _handleFixResults.Add(($"{user.Slug}: Error — {ex.Message}", true));
                }
            }

            if (totalFixed == 0)
                _handleFixResults.Insert(0, ("No handle-style URLs found. All links look good!", false));
            else
                _handleFixResults.Insert(0, ($"Done! Fixed {totalFixed} link(s) across all users.", false));
        }
        catch (Exception ex)
        {
            _handleFixResults = new() { ($"Error: {ex.Message}", true) };
        }
        finally
        {
            _isProcessing = false;
        }
    }

