    private async Task LoadBadgeIssuers()
    {
        try
        {
            _badgeIssuers = await DomainDb.GetBadgeIssuersAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading badge issuers");
            _badgeIssuers = new List<BadgeIssuer>();
