    private void DeleteSelectedDb()
    {
        _sqlError = null;
        _sqlSuccess = null;

        if (string.IsNullOrWhiteSpace(_selectedDb))
        {
            _sqlError = "Please select a database first.";
            return;
        }

        try
        {
            var dbName = Path.GetFileName(_selectedDb);

            if (!File.Exists(_selectedDb))
            {
                _sqlError = $"Database file '{dbName}' not found.";
                return;
            }

            File.Delete(_selectedDb);
            _sqlSuccess = $"Database '{dbName}' has been deleted.";
            _selectedDb = null;
            _sqlColumns = null;
            _sqlRows = null;
            LoadAvailableDbs();
        }
        catch (Exception ex)
        {
            _sqlError = $"Error deleting database: {ex.Message}";
        }
    }

