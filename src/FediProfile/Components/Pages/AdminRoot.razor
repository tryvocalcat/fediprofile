    private void SelectJob(SimpleJob job)
    {
        _selectedJob = job;
        LoadSelectedJobLogs();
    }

    private void LoadSelectedJobLogs()
    {
        if (_selectedJob == null) return;
        try
        {
            var domain = DomainDb.GetDomain() ?? "localhost";
            var domainDb = DbFactory.GetInstance(domain);
            var jobQueue = new JobQueueService(domainDb);
            _selectedJobLogs = jobQueue.GetJobLogs(_selectedJob.Id);
            // Refresh the job itself too
            _selectedJob = jobQueue.GetJobById(_selectedJob.Id) ?? _selectedJob;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading job logs for job {JobId}", _selectedJob.Id);
            _selectedJobLogs = new List<SimpleJobLog>();
        }
    }

    private async Task RetryJob(long jobId)
    {
        _isProcessing = true;
        try
        {
            var domain = DomainDb.GetDomain() ?? "localhost";
            var domainDb = DbFactory.GetInstance(domain);
            var jobQueue = new JobQueueService(domainDb);
            await jobQueue.RetryJobAsync(jobId);
            LoadJobs();
            if (_selectedJob?.Id == jobId)
            {
                _selectedJob = jobQueue.GetJobById(jobId);
                LoadSelectedJobLogs();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error retrying job {JobId}", jobId);
        }
        finally
        {
            _isProcessing = false;
        }
    }

    // ===== SQL =====

    private List<string>? _availableDbs;
    private string? _selectedDb;
    private string? _sqlQuery;
    private bool _isSqlRunning;
    private string? _sqlError;
    private string? _sqlSuccess;
    private List<string>? _sqlColumns;
    private List<Dictionary<string, object?>>? _sqlRows;

    private void LoadAvailableDbs()
    {
        try
        {
            var dbDir = Environment.GetEnvironmentVariable("DB_DATA");
            if (string.IsNullOrEmpty(dbDir))
                dbDir = Path.Combine(Directory.GetCurrentDirectory(), "App_Data");

            if (Directory.Exists(dbDir))
            {
                _availableDbs = Directory.GetFiles(dbDir, "*.db")
                    .OrderBy(f => f)
                    .ToList();
            }
            else
            {
                _availableDbs = new List<string>();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error listing databases");
            _availableDbs = new List<string>();
        }
    }

    private async Task ExecuteSql()
    {
        _sqlError = null;
        _sqlSuccess = null;
        _sqlColumns = null;
        _sqlRows = null;

        if (string.IsNullOrWhiteSpace(_selectedDb))
        {
            _sqlError = "Please select a database first.";
            return;
        }
        if (string.IsNullOrWhiteSpace(_sqlQuery))
        {
            _sqlError = "Please enter a SQL query.";
            return;
        }

        _isSqlRunning = true;
        StateHasChanged();

        try
        {
            await Task.Run(() =>
            {
                var connStr = $"Data Source={_selectedDb};Version=3;";
                using var conn = new System.Data.SQLite.SQLiteConnection(connStr);
                conn.Open();

                using var cmd = conn.CreateCommand();
                cmd.CommandText = _sqlQuery;

                var trimmed = _sqlQuery.TrimStart();
                var isSelect = trimmed.StartsWith("SELECT", StringComparison.OrdinalIgnoreCase)
                             || trimmed.StartsWith("PRAGMA", StringComparison.OrdinalIgnoreCase)
                             || trimmed.StartsWith("EXPLAIN", StringComparison.OrdinalIgnoreCase);

                if (isSelect)
                {
                    using var reader = cmd.ExecuteReader();
                    var columns = new List<string>();
                    for (int i = 0; i < reader.FieldCount; i++)
                        columns.Add(reader.GetName(i));

                    var rows = new List<Dictionary<string, object?>>();
                    while (reader.Read())
                    {
                        var row = new Dictionary<string, object?>();
                        for (int i = 0; i < reader.FieldCount; i++)
                            row[columns[i]] = reader.IsDBNull(i) ? null : reader.GetValue(i);
                        rows.Add(row);
                    }

                    _sqlColumns = columns;
                    _sqlRows = rows;
                }
                else
                {
                    var affected = cmd.ExecuteNonQuery();
                    _sqlSuccess = $"Query executed successfully. {affected} row(s) affected.";
                }
            });
        }
        catch (Exception ex)
        {
            _sqlError = ex.Message;
        }
        finally
        {
            _isSqlRunning = false;
        }
    }

    private void ClearSqlResults()
    {
        _sqlError = null;
        _sqlSuccess = null;
        _sqlColumns = null;
        _sqlRows = null;
        _sqlAllDbResults = null;
    }

    // ===== Execute SQL on All DBs =====

    private List<(string DbName, string Message, bool IsError)>? _sqlAllDbResults;

    private async Task ExecuteSqlOnAllDbs()
    {
        _sqlError = null;
        _sqlSuccess = null;
        _sqlColumns = null;
        _sqlRows = null;
        _sqlAllDbResults = null;

        if (string.IsNullOrWhiteSpace(_sqlQuery))
        {
            _sqlError = "Please enter a SQL query.";
            return;
        }

        // Ensure db list is loaded
        if (_availableDbs == null || _availableDbs.Count == 0)
            LoadAvailableDbs();

        if (_availableDbs == null || _availableDbs.Count == 0)
        {
            _sqlError = "No databases found in the data directory.";
            return;
        }

        _isSqlRunning = true;
        StateHasChanged();

        var results = new List<(string DbName, string Message, bool IsError)>();
        var query = _sqlQuery;

        try
        {
            await Task.Run(() =>
            {
                foreach (var dbPath in _availableDbs)
                {
                    var dbName = Path.GetFileName(dbPath);
                    try
                    {
                        var connStr = $"Data Source={dbPath};Version=3;";
                        using var conn = new System.Data.SQLite.SQLiteConnection(connStr);
                        conn.Open();

                        using var cmd = conn.CreateCommand();
                        cmd.CommandText = query;

                        var trimmed = query.TrimStart();
                        var isSelect = trimmed.StartsWith("SELECT", StringComparison.OrdinalIgnoreCase)
                                     || trimmed.StartsWith("PRAGMA", StringComparison.OrdinalIgnoreCase)
                                     || trimmed.StartsWith("EXPLAIN", StringComparison.OrdinalIgnoreCase);

                        if (isSelect)
                        {
                            using var reader = cmd.ExecuteReader();
                            int count = 0;
                            while (reader.Read()) count++;
                            results.Add((dbName, $"{count} row(s) returned", false));
                        }
                        else
                        {
                            var affected = cmd.ExecuteNonQuery();
                            results.Add((dbName, $"{affected} row(s) affected", false));
                        }
                    }
                    catch (Exception ex)
                    {
                        results.Add((dbName, ex.Message, true));
                    }
                }
            });

            _sqlAllDbResults = results;
            var ok = results.Count(r => !r.IsError);
            var fail = results.Count(r => r.IsError);
            _sqlSuccess = $"Executed on {results.Count} database(s): {ok} succeeded, {fail} failed.";
        }
        catch (Exception ex)
        {
            _sqlError = $"Error: {ex.Message}";
        }
        finally
        {
            _isSqlRunning = false;
        }
    }

    // ===== Helpers =====

    private static string TruncateActor(string? actorUri)
    {
        if (string.IsNullOrEmpty(actorUri)) return "—";
        if (Uri.TryCreate(actorUri, UriKind.Absolute, out var uri))
        {
            // Show host + path for readability
            var display = $"{uri.Host}{uri.AbsolutePath}";
            return display.Length > 40 ? display[..37] + "..." : display;
        }
        return actorUri.Length > 40 ? actorUri[..37] + "..." : actorUri;
    }

    private static string GetJobRowClass(SimpleJob job) =>
        job.Status == "failed" ? "job-row-failed" : "";

    private static string FormatJson(string json)
    {
        try
        {
            using var doc = JsonDocument.Parse(json);
            return JsonSerializer.Serialize(doc, new JsonSerializerOptions { WriteIndented = true });
        }
        catch
        {
            return json;
        }
    }
