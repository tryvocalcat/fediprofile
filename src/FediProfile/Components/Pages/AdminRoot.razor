        gap: 0.5rem;
        flex-wrap: wrap;
        margin-bottom: 0.5rem;
    }
    .common-queries-buttons .button {
        font-size: 0.82rem;
        padding: 0.35rem 0.75rem;
    }
    .sql-results-wrap {
        overflow-x: auto;
    }
    .sql-results-table td, .sql-results-table th {
        white-space: nowrap;
        font-size: 0.84rem;
        max-width: 350px;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .sql-cell {
        cursor: help;
        border-bottom: 1px dotted var(--text-muted, #aaa);
    }
    .sql-cell:hover {
        background-color: var(--bg-secondary, #f9f9f9);
