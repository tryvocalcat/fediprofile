    private void CleanJobs()
    {
        _cleanJobsMessage = null;
        _isProcessing = true;
        try
        {
            var domain = DomainDb.GetDomain() ?? "localhost";
            var domainDb = DbFactory.GetInstance(domain);
            var jobQueue = new JobQueueService(domainDb);
            var deleted = jobQueue.CleanCompletedJobs(threshold: 100, keep: 50);
            if (deleted > 0)
            {
                _cleanJobsMessage = $"Cleaned {deleted} old completed/failed jobs.";
                _cleanJobsIsError = false;
                LoadJobs();
                _selectedJob = null;
                _selectedJobLogs = null;
            }
            else
            {
                _cleanJobsMessage = "Nothing to clean — total jobs are under the threshold or no completed/failed jobs to remove.";
                _cleanJobsIsError = false;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error cleaning jobs");
            _cleanJobsMessage = $"Error cleaning jobs: {ex.Message}";
            _cleanJobsIsError = true;
        }
        finally
        {
            _isProcessing = false;
        }
    }

