    private async Task AddBadgeIssuer()
    {
        _badgeMessage = null;
        _badgeIsError = false;
        _isProcessing = true;

        try
        {
            if (string.IsNullOrWhiteSpace(_newIssuerUrl))
            {
                _badgeMessage = "Actor URL is required.";
                _badgeIsError = true;
                return;
            }

            var url = _newIssuerUrl.Trim();

            // Try to fetch actor info for a friendly name
            var name = url;
            try
            {
                using var http = new HttpClient { Timeout = TimeSpan.FromSeconds(15) };
                http.DefaultRequestHeaders.Add("Accept", "application/ld+json, application/activity+json, application/json");
                var resp = await http.GetStringAsync(url);
                using var doc = JsonDocument.Parse(resp);
                if (doc.RootElement.TryGetProperty("name", out var nEl) && !string.IsNullOrEmpty(nEl.GetString()))
                    name = nEl.GetString()!;
                else if (doc.RootElement.TryGetProperty("preferredUsername", out var uEl) && !string.IsNullOrEmpty(uEl.GetString()))
                    name = uEl.GetString()!;
            }
            catch { /* use URL as name */ }

            var issuerId = await DomainDb.UpsertBadgeIssuerAsync(name, url);

            _badgeMessage = $"Badge issuer '{name}' added (ID: {issuerId}).";
            _badgeIsError = false;
            _newIssuerUrl = null;
            await LoadBadgeIssuers();
        }
        catch (Exception ex)
        {
            _badgeMessage = $"Error: {ex.Message}";
            _badgeIsError = true;
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private async Task SyncBadgeIssuer(BadgeIssuer issuer)
    {
        _badgeMessage = null;
        _badgeIsError = false;
        _isProcessing = true;
        _syncingIssuerId = issuer.Id;
        StateHasChanged();

        try
        {
            var domain = DomainDb.GetDomain() ?? "localhost";
            var domainDb = DbFactory.GetInstance(domain);
            var jobQueue = new JobQueueService(domainDb);

            var jobId = await jobQueue.AddJobAsync(
                jobType: "sync_badge_issuer",
                payload: issuer.ActorUrl,
                actorUri: issuer.ActorUrl,
                createdBy: "AdminRoot",
                notes: $"Sync outbox of badge issuer: {issuer.Name}");

            _badgeMessage = $"Sync job #{jobId} enqueued for '{issuer.Name}'. Check the Job Queue tab for progress.";
            _badgeIsError = false;
        }
        catch (Exception ex)
        {
            _badgeMessage = $"Error: {ex.Message}";
            _badgeIsError = true;
        }
        finally
        {
            _isProcessing = false;
            _syncingIssuerId = null;
        }
    }

    // ===== Helpers =====

    private static string TruncateActor(string? actorUri)
    {
        if (string.IsNullOrEmpty(actorUri)) return "—";
        if (Uri.TryCreate(actorUri, UriKind.Absolute, out var uri))
        {
            // Show host + path for readability
            var display = $"{uri.Host}{uri.AbsolutePath}";
            return display.Length > 40 ? display[..37] + "..." : display;
        }
        return actorUri.Length > 40 ? actorUri[..37] + "..." : actorUri;
    }

    private static string GetJobRowClass(SimpleJob job) =>
        job.Status == "failed" ? "job-row-failed" : "";

    private static string FormatJson(string json)
    {
        try
        {
            using var doc = JsonDocument.Parse(json);
            return JsonSerializer.Serialize(doc, new JsonSerializerOptions { WriteIndented = true });
        }
        catch
        {
            return json;
        }
    }
