    private async Task AddLink()
    {
        if (_currentUserDb == null) return;
        _linkMessage = null;
        _linkIsError = false;
        _isProcessing = true;

        try
        {
            if (string.IsNullOrWhiteSpace(_newLinkName) || string.IsNullOrWhiteSpace(_newLinkUrl))
            {
                _linkMessage = "Name and URL are required.";
                _linkIsError = true;
                return;
            }

            // Auto-correct handle-style URLs for known platforms
            var (correctedNew, _) = DetectUrlHint(_selectedIconKey, _newLinkUrl, _newLinkName);
            if (correctedNew != null)
                _newLinkUrl = correctedNew;

            // Resolve @user@domain webfinger handles
            if (IsWebfingerHandle(_newLinkUrl?.Trim() ?? ""))
            {
                try
                {
                    var (wfProfileUrl, wfActorUri) = await ResolveWebfingerAsync(_newLinkUrl!.Trim());
                    if (!string.IsNullOrEmpty(wfProfileUrl))
                        _newLinkUrl = wfProfileUrl;
                }
                catch (Exception ex)
                {
                    Logger.LogInformation("WebFinger resolve failed for {Handle}: {Message}", _newLinkUrl, ex.Message);
                }
            }

            string? effectiveIcon = ResolveNewLinkIcon();

            var effectiveCategory = _newLinkCategory == "__custom__"
                ? _customCategory?.Trim()
                : _newLinkCategory;

            // Probe the URL for ActivityPub actor
            bool isActivityPub = false;
            string? actorAPUri = null;
            try
            {
                var (pubKey, privKey) = await _currentUserDb.GetActorKeysAsync();
                if (!string.IsNullOrEmpty(privKey))
                {
                    var domain = DomainDb.GetDomain() ?? "localhost";
                    var httpContext = HttpContextAccessor.HttpContext;
                    var scheme = httpContext?.Request.Scheme ?? "https";
                    var fullDomain = httpContext?.Request.Host.ToString() ?? domain;
                    var actorId = $"{scheme}://{fullDomain}/{_currentUserSlug}";
                    var keyId = $"{actorId}#main-key";

                    var actorHelper = new FediProfile.Core.ActorHelper(privKey, keyId, Logger);
                    var remoteActor = await actorHelper.FetchActorInformationAsync(_newLinkUrl.Trim());

                    if (remoteActor?.Inbox != null)
                    {
                        isActivityPub = true;
                        actorAPUri = remoteActor.Id;
/*
I don't know if this is the best UX
                        // Auto-populate name and description from actor if not already provided
                        if (string.IsNullOrWhiteSpace(_newLinkDescription))
                        {
                            var rawDesc = remoteActor.Summary ?? remoteActor.Name;
                            if (!string.IsNullOrEmpty(rawDesc))
                            {
                                // Strip HTML tags and decode entities
                                rawDesc = System.Text.RegularExpressions.Regex.Replace(rawDesc, "<[^>]+>", "");
                                rawDesc = System.Net.WebUtility.HtmlDecode(rawDesc).Trim();
                            }
                            _newLinkDescription = rawDesc;
                        }

                        if (string.IsNullOrWhiteSpace(_newLinkName) || _newLinkName.Trim() == _newLinkUrl.Trim())
                        {
                            _newLinkName = remoteActor.Name ?? remoteActor.PreferredUsername ?? _newLinkName;
                        }*/
                    }
                }
            }
            catch (Exception ex)
            {
                Logger.LogInformation("ActivityPub probe failed for {Url}: {Message}", _newLinkUrl, ex.Message);
                // Not an AP actor — that's fine, continue adding as a normal link
            }

            await _currentUserDb.UpsertLinkAsync(
                _newLinkName!.Trim(), 
                _newLinkUrl.Trim(), 
                effectiveIcon, 
                _newLinkDescription?.Trim(),
                autoBoost: false, 
                category: string.IsNullOrWhiteSpace(effectiveCategory) ? null : effectiveCategory,
                hidden: _newLinkHidden,
                isActivityPub: isActivityPub,
                actorAPUri: actorAPUri
            );

            // Reward XP only when a new link is added.
            _userProgress = await _currentUserDb.RecordActivityAsync(25);
            await TryCompleteMissionAsync("first_link");
            await CheckAutomaticMissionsAsync();

            _linkMessage = isActivityPub 
                ? "Link added! ActivityPub actor detected — you can enable AutoBoost. +25 XP"
                : "Link added! +25 XP";

            _addingNewLink = false;
            await LoadLinks();
            await RegenerateStaticProfileAsync();
            await LoadUserProgress();
            await LoadUserMissions();
            await CheckAutomaticMissionsAsync();
        }
        catch (Exception ex)
        {
            _linkMessage = $"Error adding link: {ex.Message}";
            _linkIsError = true;
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private async Task DeleteLinkById(int linkId)
    {
        if (_currentUserDb == null) return;
        _linkMessage = null;
        _linkIsError = false;
        _isProcessing = true;

        try
        {
            var link = _editableLinks?.FirstOrDefault(l => l.Id == linkId);
            if (link != null && link.AutoBoost && !string.IsNullOrEmpty(_currentUserSlug))
            {
                if (!string.IsNullOrEmpty(link.Url))
                {
                    await DomainDb.RemoveFollowingAsync(_currentUserSlug, link.ActorAPUri ?? link.Url);
                }
            }

            await _currentUserDb.DeleteLinkAsync(linkId);
            _linkMessage = "Link deleted.";
            await LoadLinks();
            await RegenerateStaticProfileAsync();
            await LoadUserProgress();
            await LoadUserMissions();
            await CheckAutomaticMissionsAsync();
        }
        catch (Exception ex)
        {
            _linkMessage = $"Error deleting link: {ex.Message}";
            _linkIsError = true;
        }
        finally
        {
            _isProcessing = false;
        }
    }

    // ===== Import Badge =====

    private async Task ImportBadge()
    {
        if (string.IsNullOrWhiteSpace(_importBadgeUrl) || _currentUserDb == null) return;

        _importBadgeMessage = null;
        _importBadgeIsError = false;
        _isImportingBadge = true;

        try
        {
            // Fetch the badge JSON-LD from the URL
            using var http = ActivityPubHelper.CreateActivityPubHttpClient();

            var response = await http.GetAsync(_importBadgeUrl);
            if (!response.IsSuccessStatusCode)
            {
                _importBadgeMessage = $"Failed to fetch URL: HTTP {(int)response.StatusCode} {response.ReasonPhrase}";
                _importBadgeIsError = true;
                return;
            }

            var json = await response.Content.ReadAsStringAsync();
            using var doc = JsonDocument.Parse(json);
            var root = doc.RootElement;

            var noteId = root.TryGetProperty("id", out var idEl) ? idEl.GetString() ?? _importBadgeUrl : _importBadgeUrl;

            // Extract all OpenBadge Assertion attachments using shared parser
            var assertions = BadgeParser.ExtractAssertions(root);

            if (assertions.Count == 0)
            {
                _importBadgeMessage = "No OpenBadge assertions found in the fetched data.";
                _importBadgeIsError = true;
                return;
            }

            // Resolve issuer details by probing the assertion's issuer and the AP actor
            var issuerInfo = await ActivityPubHelper.ResolveIssuerAsync(root, httpClient: http);

            if (string.IsNullOrEmpty(issuerInfo.ActorUrl))
            {
                _importBadgeMessage = "Could not determine badge issuer from the fetched data.";
                _importBadgeIsError = true;
                return;
            }

            // Pre-load user's verified URIs for recipient matching
            HashSet<string>? myUriSet = null;
            if (!string.IsNullOrEmpty(_currentUserSlug))
            {
                var myVerifiedUris = await DomainDb.GetVerifiedUrisAsync(_currentUserSlug);
                myUriSet = new HashSet<string>(myVerifiedUris.Select(v => v.Uri), StringComparer.OrdinalIgnoreCase);
            }

            // Upsert issuer once for the whole batch
            var issuerId = await DomainDb.UpsertBadgeIssuerAsync(
                issuerInfo.Name, issuerInfo.ActorUrl, issuerInfo.Avatar, issuerInfo.Bio);

            int importedCount = 0;
            var skippedRecipients = new List<string>();
            var importedTitles = new List<string>();

            foreach (var assertion in assertions)
            {
                // Verify recipient matches one of the user's verified URIs
                if (myUriSet != null && !myUriSet.Contains(assertion.RecipientUri))
                {
                    skippedRecipients.Add(assertion.RecipientUri);
                    continue;
                }

                var badgeRecordId = await _currentUserDb.StoreBadgeAsync(
                    noteId, issuerId, assertion.BadgeTitle, assertion.BadgeImage,
                    assertion.BadgeDescription, assertion.IssuedOn);

                if (badgeRecordId > 0)
                {
                    importedCount++;
                    importedTitles.Add(assertion.BadgeTitle);
                }
            }

            // Build result message
            if (importedCount > 0)
            {
                var titles = string.Join(", ", importedTitles.Select(t => $"'{t}'"));

                _userProgress = await _currentUserDb.RecordActivityAsync(importedCount * 50);
                await TryCompleteMissionAsync("first_badge");
                await CheckAutomaticMissionsAsync();

                var earnedXp = importedCount * 50;

                _importBadgeMessage = importedCount == 1
                    ? $"Badge {titles} imported successfully! +{earnedXp} XP"
                    : $"{importedCount} badges imported: {titles} +{earnedXp} XP";

                _importBadgeUrl = null;

                await LoadBadgeIssuers();
                await LoadReceivedBadges();
                await RegenerateStaticProfileAsync();
                await LoadUserProgress();
                await LoadUserMissions();
                await CheckAutomaticMissionsAsync();
                await LoadLinks();

                _badgeTab = "badges";
            }
            else if (skippedRecipients.Count > 0)
            {
                var recipientList = string.Join(", ", skippedRecipients);
                _importBadgeMessage = $"This badge was issued to {recipientList} which is not one of your verified URIs. " +
                    "Add the matching URI to your Mastodon profile and re-sync your verified URIs first.";
                _importBadgeIsError = true;
            }
            else
            {
                _importBadgeMessage = "Badge was already imported or could not be stored.";
                _importBadgeIsError = true;
            }
        }
        catch (Exception ex)
        {
            _importBadgeMessage = $"Error importing badge: {ex.Message}";
            _importBadgeIsError = true;
        }
        finally
        {
            _isImportingBadge = false;
        }
    }

