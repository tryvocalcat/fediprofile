    // ===== Link Sorting =====

    /// <summary>
    /// Ensures every link in the group has a unique, sequential SortOrder.
    /// Called before any swap so that links loaded with SortOrder=0 get proper values.
    /// </summary>
    private void NormalizeSortOrders(List<EditableLink> group)
    {
        // Check if all values are already unique
        var values = group.Select(l => l.SortOrder).ToList();
        if (values.Distinct().Count() == values.Count && values.SequenceEqual(values.OrderBy(v => v)))
            return;

        // Reassign 1, 2, 3... preserving current relative order
        for (int i = 0; i < group.Count; i++)
        {
            group[i].SortOrder = i + 1;
        }
    }

    private bool IsFirstInGroup(EditableLink link)
    {
        if (_editableLinks == null) return true;
        var group = _editableLinks
            .Where(l => (l.Category ?? "") == (link.Category ?? ""))
            .OrderBy(l => l.SortOrder)
            .ToList();
        return group.Count == 0 || group[0].Id == link.Id;
    }

    private bool IsLastInGroup(EditableLink link)
    {
        if (_editableLinks == null) return true;
        var group = _editableLinks
            .Where(l => (l.Category ?? "") == (link.Category ?? ""))
            .OrderBy(l => l.SortOrder)
            .ToList();
        return group.Count == 0 || group[^1].Id == link.Id;
    }

    private async Task MoveLinkUp(EditableLink link)
    {
        if (_currentUserDb == null || _editableLinks == null) return;
        var group = _editableLinks
            .Where(l => (l.Category ?? "") == (link.Category ?? ""))
            .OrderBy(l => l.SortOrder)
            .ThenBy(l => l.Id)
            .ToList();

        NormalizeSortOrders(group);

        var idx = group.FindIndex(l => l.Id == link.Id);
        if (idx <= 0) return;

        // Swap sort orders with the previous item
        var prev = group[idx - 1];
        (prev.SortOrder, link.SortOrder) = (link.SortOrder, prev.SortOrder);

        await PersistSortOrdersAsync();
    }

    private async Task MoveLinkDown(EditableLink link)
    {
        if (_currentUserDb == null || _editableLinks == null) return;
        var group = _editableLinks
            .Where(l => (l.Category ?? "") == (link.Category ?? ""))
            .OrderBy(l => l.SortOrder)
            .ThenBy(l => l.Id)
            .ToList();

        NormalizeSortOrders(group);

        var idx = group.FindIndex(l => l.Id == link.Id);
        if (idx < 0 || idx >= group.Count - 1) return;

        // Swap sort orders with the next item
        var next = group[idx + 1];
        (next.SortOrder, link.SortOrder) = (link.SortOrder, next.SortOrder);

        await PersistSortOrdersAsync();
    }

    private async Task PersistSortOrdersAsync()
    {
        if (_currentUserDb == null || _editableLinks == null) return;
        _linkMessage = null;
        _linkIsError = false;

        try
        {
            var sortOrders = _editableLinks.Select(l => (l.Id, l.SortOrder));
            await _currentUserDb.UpdateLinkSortOrdersAsync(sortOrders);
            await RegenerateStaticProfileAsync();
        }
        catch (Exception ex)
        {
            _linkMessage = $"Error updating sort order: {ex.Message}";
            _linkIsError = true;
        }
    }

