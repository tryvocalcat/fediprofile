    private async Task SaveLinkInline(EditableLink link)
    {
        if (_currentUserDb == null) return;
        _linkMessage = null;
        _linkIsError = false;

        // Auto-correct handle-style URLs for known platforms
        var (correctedEdit, _) = DetectUrlHint(link.SelectedIconKey, link.Url, link.Name);
        if (correctedEdit != null)
            link.Url = correctedEdit;

        // Resolve @user@domain webfinger handles
        if (IsWebfingerHandle(link.Url?.Trim() ?? ""))
        {
            try
            {
                var (wfProfileUrl, wfActorUri) = await ResolveWebfingerAsync(link.Url!.Trim());
                if (!string.IsNullOrEmpty(wfProfileUrl))
                {
                    link.Url = wfProfileUrl;
                    if (!string.IsNullOrEmpty(wfActorUri))
                    {
                        link.IsActivityPub = true;
                        link.ActorAPUri = wfActorUri;
                    }
                }
            }
            catch (Exception ex)
            {
                Logger.LogInformation("WebFinger resolve failed for {Handle}: {Message}", link.Url, ex.Message);
            }
        }

        try
        {
            var effectiveCategory = link.Category == "__custom__"
                ? link.CustomCategory?.Trim()
                : link.Category;

            await _currentUserDb.UpdateLinkAsync(
                link.Id,
                link.Name,
                link.Url,
                link.Icon,
                link.Description,
                link.AutoBoost,
                string.IsNullOrWhiteSpace(effectiveCategory) ? null : effectiveCategory,
                link.Hidden,
                link.IsActivityPub,
                link.ActorAPUri
            );

            if (link.Category == "__custom__" && !string.IsNullOrWhiteSpace(link.CustomCategory))
            {
                link.Category = link.CustomCategory.Trim();
                link.CustomCategory = null;
            }

            link.IsEditing = false;
            link.IconGridOpen = false;
            await RegenerateStaticProfileAsync();
            _linkMessage = "Link saved!";
            RebuildAvailableCategories();
        }
        catch (Exception ex)
        {
            _linkMessage = $"Error saving link: {ex.Message}";
            _linkIsError = true;
        }
    }

