    private static string FormatPostDate(string? utcString)
    {
        if (string.IsNullOrEmpty(utcString)) return "";
        if (DateTime.TryParse(utcString, null, System.Globalization.DateTimeStyles.RoundtripKind, out var dt))
        {
            var ago = DateTime.UtcNow - dt.ToUniversalTime();
            if (ago.TotalMinutes < 1) return "just now";
            if (ago.TotalHours < 1) return $"{(int)ago.TotalMinutes}m ago";
            if (ago.TotalDays < 1) return $"{(int)ago.TotalHours}h ago";
            if (ago.TotalDays < 30) return $"{(int)ago.TotalDays}d ago";
            return dt.ToString("MMM d, yyyy");
        }
        return utcString;
    }

