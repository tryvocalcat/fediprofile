            _customIconUrl = faviconUrl;
        }
        else
        {
            _selectedIconKey = "__custom__";
            _customIconUrl = null;
        }
        _newLinkIconGridOpen = false;
    }

    private async Task<string?> ResolveFaviconUrl(string? url)
    {
        if (string.IsNullOrWhiteSpace(url)) return null;
        try
        {
            if (!Uri.TryCreate(url, UriKind.Absolute, out var uri)) return null;
            var origin = $"{uri.Scheme}://{uri.Host}";

            using var http = new HttpClient { Timeout = TimeSpan.FromSeconds(8) };
            http.DefaultRequestHeaders.UserAgent.ParseAdd("FediProfile/1.0");

            // Try to parse the HTML for a <link rel="icon"> or <link rel="shortcut icon">
            try
            {
                var html = await http.GetStringAsync(url);
                var match = System.Text.RegularExpressions.Regex.Match(
                    html,
                    @"<link[^>]*rel=[""'](?:shortcut )?icon[""'][^>]*href=[""']([^""']+)[""']",
                    System.Text.RegularExpressions.RegexOptions.IgnoreCase);
                if (!match.Success)
                {
                    // Also try href before rel
                    match = System.Text.RegularExpressions.Regex.Match(
                        html,
                        @"<link[^>]*href=[""']([^""']+)[""'][^>]*rel=[""'](?:shortcut )?icon[""']",
                        System.Text.RegularExpressions.RegexOptions.IgnoreCase);
                }
                if (match.Success)
                {
                    var href = match.Groups[1].Value;
                    if (href.StartsWith("//")) return $"{uri.Scheme}:{href}";
                    if (href.StartsWith("/")) return $"{origin}{href}";
                    if (href.StartsWith("http")) return href;
                    return $"{origin}/{href}";
                }
            }
            catch { /* fall through to /favicon.ico */ }

            // Fallback: try /favicon.ico
            var faviconIco = $"{origin}/favicon.ico";
            var resp = await http.SendAsync(new HttpRequestMessage(HttpMethod.Head, faviconIco));
            if (resp.IsSuccessStatusCode) return faviconIco;

            return null;
        }
        catch
        {
            return null;
        }
    }

    // ===== Toggle AutoBoost / Hidden for existing links =====

    private async Task ToggleAutoBoost(EditableLink link)
    {
        if (_currentUserDb == null || string.IsNullOrEmpty(_currentUserSlug)) return;
        _linkMessage = null;
        _linkIsError = false;

        var newValue = !link.AutoBoost;

        if (newValue)
        {
            // Turning ON → follow the actor
            try
            {
                var (pubKey, privKey) = await _currentUserDb.GetActorKeysAsync();
                if (string.IsNullOrEmpty(privKey))
                {
                    _linkMessage = "Cannot enable AutoBoost: missing private key.";
                    _linkIsError = true;
                    return;
                }

                var domain = DomainDb.GetDomain() ?? "localhost";
                var httpContext = HttpContextAccessor.HttpContext;
                var scheme = httpContext?.Request.Scheme ?? "https";
                var fullDomain = httpContext?.Request.Host.ToString() ?? domain;
                var actorId = $"{scheme}://{fullDomain}/{_currentUserSlug}";
                var remoteActor = await FetchActivityPubActorAsync(link.Url, link.ActorAPUri);

                if (remoteActor?.Inbox == null)
                {
                    _linkMessage = "Cannot enable AutoBoost: could not resolve the actor or find their inbox.";
                    _linkIsError = true;
                    return;
                }

                // Store the actor's AP URI (their canonical id) for matching incoming Create activities
                link.ActorAPUri = remoteActor.Id;
                link.IsActivityPub = true;
                if (!string.IsNullOrWhiteSpace(remoteActor.Url))
                    link.Url = remoteActor.Url;

                var (followSuccess, followError) = await FollowService.SendFollowRequestAsync(
                    link.ActorAPUri, remoteActor.Inbox, _currentUserDb, actorId);

                if (!followSuccess)
                {
                    _linkMessage = $"Cannot enable AutoBoost: failed to follow the actor. {followError}";
                    _linkIsError = true;
                    return;
                }

                await DomainDb.AddFollowingAsync(_currentUserSlug, link.ActorAPUri);
            }
            catch (Exception ex)
            {
                _linkMessage = $"Cannot enable AutoBoost: {ex.Message}";
                _linkIsError = true;
                return;
            }
        }
        else
        {
            // Turning OFF → unfollow the actor
            try
            {
                var (pubKey, privKey) = await _currentUserDb.GetActorKeysAsync();
                if (!string.IsNullOrEmpty(privKey) && !string.IsNullOrEmpty(link.Url))
                {
                    var domain = DomainDb.GetDomain() ?? "localhost";
                    var httpContext = HttpContextAccessor.HttpContext;
                    var scheme = httpContext?.Request.Scheme ?? "https";
                    var fullDomain = httpContext?.Request.Host.ToString() ?? domain;
                    var actorId = $"{scheme}://{fullDomain}/{_currentUserSlug}";
                    var remoteActor = await FetchActivityPubActorAsync(link.Url, link.ActorAPUri);
                    var followTarget = link.ActorAPUri ?? remoteActor?.Id ?? link.Url;

                    if (remoteActor?.Id != null)
                        link.ActorAPUri = remoteActor.Id;
                    if (!string.IsNullOrWhiteSpace(remoteActor?.Url))
                        link.Url = remoteActor.Url;

                    if (remoteActor?.Inbox != null)
                    {
                        await FollowService.SendUnfollowAsync(followTarget, remoteActor.Inbox, _currentUserDb, actorId);
                    }

                    await DomainDb.RemoveFollowingAsync(_currentUserSlug, followTarget);
                }
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Error unfollowing actor during AutoBoost toggle off");
            }
        }

        // Update in-memory and persist to DB
        link.AutoBoost = newValue;
        try
        {
            var effectiveCategory = link.Category == "__custom__"
                ? link.CustomCategory?.Trim()
                : link.Category;

            await _currentUserDb.UpdateLinkAsync(
                link.Id, link.Name, link.Url, link.Icon, link.Description,
                link.AutoBoost,
                string.IsNullOrWhiteSpace(effectiveCategory) ? null : effectiveCategory,
                link.Hidden,
                link.IsActivityPub,
                link.ActorAPUri);

            await RegenerateStaticProfileAsync();
            _linkMessage = newValue ? "AutoBoost enabled – follow request sent." : "AutoBoost disabled – unfollowed.";
        }
        catch (Exception ex)
        {
            _linkMessage = $"Error updating link: {ex.Message}";
            _linkIsError = true;
        }
    }

    private async Task ToggleHidden(EditableLink link)
    {
        if (_currentUserDb == null) return;
