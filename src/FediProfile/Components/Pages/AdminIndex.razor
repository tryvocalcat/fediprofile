    private async Task TryCompleteMissionAsync(string missionCode)
    {
        if (_currentUserDb == null) return;

        var completed = await _currentUserDb.CompleteMissionAsync(missionCode);

        if (completed)
        {
            _userProgress = await _currentUserDb.GetUserProgressAsync();
            await LoadUserMissions();
            await CheckAutomaticMissionsAsync();
        }
    }

    private async Task CheckAutomaticMissionsAsync()
    {
        if (_currentUserDb == null) return;

        var progress = await _currentUserDb.GetUserProgressAsync();

        foreach (var milestone in LevelMissionThresholds)
        {
            if (progress.Level >= milestone.Level)
            {
                await _currentUserDb.CompleteMissionAsync(milestone.Code);
            }
        }

        foreach (var milestone in StreakMissionThresholds)
        {
            if (progress.CurrentStreakDays >= milestone.Days)
            {
                await _currentUserDb.CompleteMissionAsync(milestone.Code);
            }
        }

        _userProgress = await _currentUserDb.GetUserProgressAsync();
        await LoadUserMissions();
    }

