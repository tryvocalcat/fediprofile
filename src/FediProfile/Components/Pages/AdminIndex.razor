    private async Task<PendingBadgeImport> PrepareBadgeImportAsync(string importUrl)
    {
        using var http = ActivityPubHelper.CreateActivityPubHttpClient();

        var response = await http.GetAsync(importUrl);
        if (!response.IsSuccessStatusCode)
            throw new InvalidOperationException($"Failed to fetch URL: HTTP {(int)response.StatusCode} {response.ReasonPhrase}");

        var json = await response.Content.ReadAsStringAsync();
        using var doc = JsonDocument.Parse(json);
        var root = doc.RootElement;

        var noteId = root.TryGetProperty("id", out var idEl) ? idEl.GetString() ?? importUrl : importUrl;

        var parsedAssertions = BadgeParser.ExtractAssertions(root);
        if (parsedAssertions.Count == 0)
            throw new InvalidOperationException("No OpenBadge assertions found in the fetched data.");

        var issuerInfo = await ActivityPubHelper.ResolveIssuerAsync(root, httpClient: http);
        if (string.IsNullOrEmpty(issuerInfo.ActorUrl))
            throw new InvalidOperationException("Could not determine badge issuer from the fetched data.");

        HashSet<string>? myUriSet = null;
        if (!string.IsNullOrEmpty(_currentUserSlug))
        {
            var myVerifiedUris = await DomainDb.GetVerifiedUrisAsync(_currentUserSlug);
            myUriSet = new HashSet<string>(myVerifiedUris.Select(v => v.Uri), StringComparer.OrdinalIgnoreCase);
        }

        var assertions = parsedAssertions
            .Select(assertion => new PendingBadgeAssertion(
                assertion.RecipientUri,
                assertion.BadgeTitle,
                assertion.BadgeImage,
                assertion.BadgeDescription,
                assertion.IssuedOn))
            .ToList();

        var mismatchedRecipients = assertions
            .Where(assertion => myUriSet != null && !myUriSet.Contains(assertion.RecipientUri))
            .Select(assertion => assertion.RecipientUri)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        return new PendingBadgeImport(importUrl, noteId, issuerInfo, assertions, mismatchedRecipients);
    }

    private async Task CompleteBadgeImportAsync(PendingBadgeImport pendingImport)
    {
        if (_currentUserDb == null) return;

        var issuerId = await DomainDb.UpsertBadgeIssuerAsync(
            pendingImport.IssuerInfo.Name,
            pendingImport.IssuerInfo.ActorUrl,
            pendingImport.IssuerInfo.Avatar,
            pendingImport.IssuerInfo.Bio);

        int importedCount = 0;
        var importedTitles = new List<string>();

        foreach (var assertion in pendingImport.Assertions)
        {
            var badgeRecordId = await _currentUserDb.StoreBadgeAsync(
                pendingImport.NoteId,
                issuerId,
                assertion.BadgeTitle,
                assertion.BadgeImage,
                assertion.BadgeDescription,
                assertion.IssuedOn);

            if (badgeRecordId > 0)
            {
                importedCount++;
                importedTitles.Add(assertion.BadgeTitle);
            }
        }

        if (importedCount == 0)
        {
            _importBadgeMessage = "Badge was already imported or could not be stored.";
            _importBadgeIsError = true;
            return;
        }

        var titles = string.Join(", ", importedTitles.Select(t => $"'{t}'"));
        _importBadgeMessage = importedCount == 1
            ? $"Badge {titles} imported successfully!"
            : $"{importedCount} badges imported: {titles}";
        _importBadgeUrl = null;
        _pendingBadgeImport = null;
        await LoadBadgeIssuers();
        await LoadReceivedBadges();
        await RegenerateStaticProfileAsync();
        _badgeTab = "badges";
    }

