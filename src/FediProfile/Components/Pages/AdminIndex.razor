    private async Task ToggleFeaturedBadge(ReceivedBadge badge)
    {
        if (_currentUserDb == null) return;

        try
        {
            var shouldFeature = !badge.IsFeatured;

            var featuredCount = _receivedBadges?
                .Count(b => b.IsFeatured && b.Id != badge.Id) ?? 0;

            if (shouldFeature && featuredCount >= 3)
            {
                _profileMessage = "You can only feature up to 3 badges.";
                _profileIsError = true;
                return;
            }

            await _currentUserDb.SetBadgeFeaturedAsync(badge.Id, shouldFeature);

            badge.IsFeatured = shouldFeature;

            _userProgress = await _currentUserDb.RecordActivityAsync(5);

            if (shouldFeature)
            {
                await TryCompleteMissionAsync("first_featured_badge");
            }

            await LoadReceivedBadges();
            await RegenerateStaticProfileAsync();
            await LoadUserProgress();
            await LoadUserMissions();
            await CheckAutomaticMissionsAsync();

            _profileMessage = shouldFeature
                ? "Badge added to featured badges."
                : "Badge removed from featured badges.";

            _profileIsError = false;

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to toggle featured badge {BadgeId}", badge.Id);
            _profileMessage = $"Could not update featured badge: {ex.Message}";
            _profileIsError = true;
        }
    }
    
