                                        </button>
                                    </div>
                                </div>
                            }

                        <div style="display:flex;gap:0.5rem;align-items:center">
                                <input type="text" @bind="_importBadgeUrl" @bind:after="OnImportBadgeUrlChanged" placeholder="https://badgefed.org/view/grant/..." class="form-control" style="flex:1" />
                            <button class="button button-primary" @onclick="ImportBadge" disabled="@(_isImportingBadge || string.IsNullOrWhiteSpace(_importBadgeUrl))">
