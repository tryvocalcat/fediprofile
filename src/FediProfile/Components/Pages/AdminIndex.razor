                                </div>
                                <button class="button button-primary button-small" @onclick="SaveAllowedThemesAsync">Save theme options</button>
                            </div>
                            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:0.55rem">
                                @foreach (var theme in Themes.All)
                                {
                                    <label style="display:flex;align-items:center;gap:0.5rem;padding:0.55rem 0.65rem;border:1px solid var(--border, #e0e0e0);border-radius:8px;background:var(--bg, #fff);cursor:pointer">
                                        <input type="checkbox" checked="@(_allowedThemeSelection.GetValueOrDefault(theme.FileName))" @onchange="args => ToggleAllowedTheme(theme.FileName, args.Value is bool flag && flag)" />
                                        <span style="font-size:0.9rem">@theme.DisplayName</span>
                                    </label>
                                }
                            </div>
                        </div>
                    }

                    <!-- Skip Replies -->
                    <div style="display:flex;align-items:flex-start;gap:0.75rem;padding:0.75rem;border:1px solid var(--border, #e0e0e0);border-radius:8px;background:var(--bg-subtle, #f8f9fa)">
                        <label class="pe-toggle" style="flex-shrink:0;margin-top:0.1rem;cursor:pointer" title="@(_profileSkipReplies ? "Only boosting main posts" : "Boosting all posts including replies")">
                            <input type="checkbox" checked="@_profileSkipReplies" @onchange="OnSkipRepliesChanged" />
                            <span class="pe-toggle-badge @(_profileSkipReplies ? "pe-toggle-on" : "")">@(_profileSkipReplies ? "ON" : "OFF")</span>
                        </label>
                        <div>
                            <strong style="font-size:0.92rem">Skip Replies</strong>
                            <p class="muted" style="font-size:0.82rem;margin:0.15rem 0 0">Only boost original/main posts. When enabled, replies from your linked accounts will not be announced to your followers.</p>
                        </div>
                    </div>

                    <!-- Show Recent Posts -->
                    <div style="display:flex;align-items:flex-start;gap:0.75rem;padding:0.75rem;border:1px solid var(--border, #e0e0e0);border-radius:8px;background:var(--bg-subtle, #f8f9fa)">
                        <label class="pe-toggle" style="flex-shrink:0;margin-top:0.1rem;cursor:pointer" title="@(_profileShowRecentPosts ? "Recent posts visible on public profile" : "Recent posts hidden from public profile")">
                            <input type="checkbox" checked="@_profileShowRecentPosts" @onchange="OnShowRecentPostsChanged" />
                            <span class="pe-toggle-badge @(_profileShowRecentPosts ? "pe-toggle-on" : "")">@(_profileShowRecentPosts ? "ON" : "OFF")</span>
                        </label>
                        <div>
                            <strong style="font-size:0.92rem">Show Recent Posts</strong>
                            <p class="muted" style="font-size:0.82rem;margin:0.15rem 0 0">Display recently boosted posts on your public profile page. When disabled, the Recent Activity section is hidden from visitors.</p>
                        </div>
                    </div>
                </div>
                    </article>
                </div>
            }

            @if (_activeAdminTab == "danger")
            {
                <div class="dashboard-panel">
                    <!-- Danger Zone -->
                    <article class="card admin-card-spaced" style="border:2px solid #dc3545;">
                <h2 style="color:#dc3545;">⚠️ Danger Zone</h2>
                <p class="muted">Permanently delete your account and all associated data. This action cannot be undone.</p>

                @if (!string.IsNullOrEmpty(_deleteAccountMessage))
                {
                    <div class="alert @(_deleteAccountIsError ? "alert-error" : "alert-success")">
                        @_deleteAccountMessage
