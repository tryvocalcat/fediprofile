    private async Task LoadProfileSettings()
    {
        if (_currentUserDb == null) return;
        try
        {
            var settings = await _currentUserDb.GetSettingsAsync();
            var allowedThemeFiles = await DomainDb.GetAllowedUiThemesAsync();
            _availableThemes = Themes.GetAvailableOptions(allowedThemeFiles);
            _allowedThemeSelection = Themes.All.ToDictionary(
                theme => theme.FileName,
                theme => _availableThemes.Any(option => option.FileName == theme.FileName),
                StringComparer.OrdinalIgnoreCase);

            if (settings != null)
            {
                _profileDisplayName = settings.ActorUsername;
                _profileBio = settings.ActorBio;
                _profileAvatarUrl = settings.ActorAvatarUrl;
                _profileTheme = Themes.ResolveForSelection(settings.UiTheme, allowedThemeFiles);
                _profileSkipReplies = settings.SkipReplies;
                _profileShowRecentPosts = settings.ShowRecentPosts;
            }
            else
            {
                _profileTheme = Themes.ResolveForSelection(Themes.DefaultFile, allowedThemeFiles);
            }
        }
        catch
        {
            _profileTheme = Themes.DefaultFile;
        }
    }

