    private void SetAdminTab(string tab)
    {
        if (tab == "followers" && _hideFollowersTab) return;
        if (tab == "activity" && _hideRecentPostsTab) return;
        if (tab == "settings" && _hideSettingsTab) return;
        _activeAdminTab = tab;
    }

    protected override async Task OnInitializedAsync()
    {
        _joinMastodonUrl = await DomainDb.GetJoinMastodonUrlAsync();
        _hideFollowersTab = await DomainDb.GetHideFollowersTabAsync();
        _hideRecentPostsTab = await DomainDb.GetHideRecentPostsTabAsync();
        _hideSettingsTab = await DomainDb.GetHideSettingsTabAsync();

        var allowedThemeFiles = await DomainDb.GetAllowedUiThemesAsync();
        _availableThemes = Themes.GetAvailableOptions(allowedThemeFiles);
        _allowedThemeSelection = Themes.All.ToDictionary(
            theme => theme.FileName,
            theme => _availableThemes.Any(option => option.FileName == theme.FileName),
            StringComparer.OrdinalIgnoreCase);

        if (_hideFollowersTab && _activeAdminTab == "followers")
            _activeAdminTab = "profile";
        if (_hideRecentPostsTab && _activeAdminTab == "activity")
            _activeAdminTab = "profile";
        if (_hideSettingsTab && _activeAdminTab == "settings")
            _activeAdminTab = "profile";
        // Parse integration ref from query string
        var navUri = new Uri(Navigation.Uri);
        var qs = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(navUri.Query);
        if (qs.ContainsKey("ref"))
            _integrationRef = FediProfile.Core.IntegrationRef.FromQueryParam(qs["ref"]);

        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        var mastodonUser = state.User.FindFirst(ClaimTypes.Name)?.Value;
        var mastodonHost = state.User.FindFirst("urn:mastodon:hostname")?.Value;
        
        if (!string.IsNullOrWhiteSpace(mastodonUser) && !string.IsNullOrWhiteSpace(mastodonHost))
        {
            _signedInAs = $"{mastodonUser}@{mastodonHost}";
        }
        else
        {
            _signedInAs = state.User.Identity?.Name;
        }

        _currentUserSlug = null;
        _isAuthorized = false;
        
        if (!string.IsNullOrWhiteSpace(mastodonUser) && !string.IsNullOrWhiteSpace(mastodonHost))
        {
            var dbUser = await DomainDb.GetUserByMastodonAsync(mastodonUser, mastodonHost);
            if (dbUser.HasValue)
            {
                _currentUserSlug = dbUser.Value.Slug;
                _isAuthorized = true;
                _isRootUser = await DomainDb.IsRootUserAsync(dbUser.Value.Id);
            }
        }

        // Impersonation: if root and ?impersonate=slug is set, switch to that user
        _impersonating = false;
        if (_isRootUser && !string.IsNullOrWhiteSpace(ImpersonateSlug))
        {
            var allUsers = await DomainDb.GetAllUsersAsync();
            var targetUser = allUsers?.FirstOrDefault(u => u.Slug.Equals(ImpersonateSlug, StringComparison.OrdinalIgnoreCase));
            if (targetUser is { } t && !string.IsNullOrEmpty(t.Slug))
            {
                _currentUserSlug = t.Slug;
                _impersonating = true;
            }
        }

        _dbName = Path.GetFileName(DomainDb.DbPath);
        _currentDomain = DomainDb.GetDomain() ?? "localhost";

        if (_isAuthorized && !string.IsNullOrEmpty(_currentUserSlug))
        {
            var domain = DomainDb.GetDomain() ?? "localhost";
            _currentUserDb = DbFactory.GetInstance(domain, _currentUserSlug);

            var (existingPubKey, _) = await _currentUserDb.GetActorKeysAsync();
            if (string.IsNullOrEmpty(existingPubKey))
            {
                var keyPair = await CryptoService.GenerateKeyPairAsync();
                await _currentUserDb.SetActorKeysAsync(keyPair.PublicKeyPem, keyPair.PrivateKeyPem);
            }

            await LoadProfileSettings();
            await LoadLinks();
            await LoadBadgeIssuers();
            await LoadReceivedBadges();
            await LoadVerifiedUris();
            await LoadFollowers();
            await LoadRecentPosts();
        }
    }

