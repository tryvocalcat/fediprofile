            @if (_activeAdminTab == "settings")
            {
                <div class="dashboard-panel">
                    <!-- Settings -->
                    <article class="card admin-card-spaced">
                <h2>Settings</h2>
                <p class="muted">Configure how your profile behaves.</p>

                <div style="margin-top:0.75rem;display:flex;flex-direction:column;gap:1rem">
                    @if (_isRootUser)
                    {
                        <div style="padding:0.75rem;border:1px solid var(--border, #e0e0e0);border-radius:8px;background:var(--bg-subtle, #f8f9fa)">
