    private async Task SaveAllowedThemesAsync()
    {
        var selectedThemes = Themes.All
            .Where(theme => _allowedThemeSelection.TryGetValue(theme.FileName, out var isEnabled) && isEnabled)
            .Select(theme => theme.FileName)
            .ToList();

        if (selectedThemes.Count == 0)
            selectedThemes = Themes.All.Select(theme => theme.FileName).ToList();

        await DomainDb.SetAllowedUiThemesAsync(selectedThemes);

        var allowedThemeFiles = await DomainDb.GetAllowedUiThemesAsync();
        _availableThemes = Themes.GetAvailableOptions(allowedThemeFiles);
        _allowedThemeSelection = Themes.All.ToDictionary(
            theme => theme.FileName,
            theme => _availableThemes.Any(option => option.FileName == theme.FileName),
            StringComparer.OrdinalIgnoreCase);

        if (_currentUserDb != null && !string.IsNullOrWhiteSpace(_profileTheme) && !_availableThemes.Any(option => option.FileName == _profileTheme))
        {
            _profileTheme = _availableThemes.FirstOrDefault()?.FileName ?? Themes.DefaultFile;
            await _currentUserDb.UpsertSettingsAsync(uiTheme: _profileTheme);
            await RegenerateStaticProfileAsync();
        }
    }

