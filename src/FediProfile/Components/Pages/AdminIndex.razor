                    <div style="padding:1.25rem;border:1px dashed var(--border, #d0d0d0);border-radius:10px;background:var(--bg-subtle, #f8f9fa);text-align:center">
                        <p style="font-size:0.95rem;font-weight:600;margin:0 0 0.4rem">Want to show your latest posts and activity?</p>
                        <p class="muted" style="font-size:0.85rem;margin:0 0 0.6rem;line-height:1.5">
                            Add a fediverse account — such as <strong>Mastodon</strong>, <strong>Pixelfed</strong>, or <strong>Misskey</strong> — as a link with <em>AutoBoost</em> enabled.<br />
                            Your recent posts will then appear here and on your public profile automatically.
                        </p>
                        <p class="muted" style="font-size:0.8rem;margin:0">Head to the <strong>Links</strong> section above to add one.</p>
                        <p class="muted" style="font-size:0.8rem;margin:0.5rem 0 0">Unsure where to start? <a href="@_joinMastodonUrl" target="_blank" rel="noopener">Join Mastodon ↗</a></p>
                    </div>
                }
                else
                {
                    <div style="display:flex;flex-direction:column;gap:0.75rem;margin-top:0.75rem">
                        @foreach (var post in _recentPosts)
