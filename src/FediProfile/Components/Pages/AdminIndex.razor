@page "/admin/"
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Forms
@using System.Security.Claims
@using System.Text.Json
@using System.Net.Http.Headers
@using FediProfile.Core
@using FediProfile.Models
@attribute [Authorize]
@layout FediProfile.Components.Layouts.MainLayout
@rendermode InteractiveServer

@inject UserScopedDb UserDb
@inject DomainScopedDb DomainDb
@inject LocalDbFactory DbFactory
@inject AuthenticationStateProvider AuthStateProvider
@inject IHttpContextAccessor HttpContextAccessor
@inject UserContextAccessor UserContextAccessor
@inject FollowService FollowService
@inject ILogger<AdminIndex> Logger
@inject IWebHostEnvironment WebEnv
@inject NavigationManager Navigation
@inject ProfileHtmlService ProfileHtml
@inject ActorService ActorService
@inject IJSRuntime JS

<section class="admin-shell">
    <header class="admin-header">
        <div>
            <h1 class="admin-title">My Profile</h1>
            @if (_impersonating)
            {
                <p class="admin-subtitle" style="color:#e67e22;font-weight:600;">Impersonating: @_currentUserSlug</p>
            }
            else
            {
                <p class="admin-subtitle">Edit your links, bio, and badges.</p>
            }
        </div>
        <div style="display:flex;gap:0.5rem;align-items:center">
            @if (_impersonating)
            {
                <a href="/admin/" class="button button-ghost">Stop Impersonating</a>
            }
        </div>
       
    </header>

    @if (!_isAuthorized)
    {
        <div class="admin-section">
            <article class="card">
                <div class="alert alert-error">
                    Your Mastodon account is not associated with any profile on this instance.
                    <a href="/login">Register a new profile</a> or contact the administrator.
                </div>
            </article>
        </div>
    }

    @if (_isAuthorized && !string.IsNullOrEmpty(_currentUserSlug))
    {
        <div class="admin-section">
            <!-- Profile Editor (WYSIWYG) -->
            <article class="pe-card">
                @if (!string.IsNullOrEmpty(_profileMessage))
                {
                    <div class="alert @(_profileIsError ? "alert-error" : "alert-success")">
                        @_profileMessage
                    </div>
                }

                <div class="pe-save-bar pe-save-bar-top">
                    <div class="pe-save-bar-left">
                        <label class="muted" style="white-space:nowrap;margin:0">Theme</label>
                        <select value="@_profileTheme" @onchange="OnThemeChanged" class="form-control">
                            @foreach (var t in Themes.All)
                            {
                                <option value="@t.FileName">@t.DisplayName</option>
                            }
                        </select>
                        @if (_themeSaved)
                        {
                            <span class="muted" style="font-size:0.8rem">✓ saved</span>
                        }
                    </div>
                    <div class="pe-save-bar-right">
                        @if (_integrationRef != null)
                        {
                            <button class="button button-success button-small" @onclick="CopyProfileUrl">
                                <svg style="width:16px;height:16px;vertical-align:-2px;margin-right:0.3rem;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                                Copy URL
                            </button>
                            @if (_copied)
                            {
                                <span class="muted" style="font-size:0.8rem;align-self:center;">Copied!</span>
                            }
                        }
                        <a href="/@_currentUserSlug" target="_blank" class="button button-ghost button-small">Preview ↗</a>
                        <button class="button button-primary" @onclick="SaveProfile" disabled="@_isProcessing">
                            @(_isProcessing ? "Saving..." : "Save Profile")
                        </button>
                    </div>
                </div>

                <!-- Avatar -->
                <div class="pe-avatar-section">
                    <div class="pe-avatar-frame">
                        @if (!string.IsNullOrEmpty(_profileAvatarUrl))
                        {
                            <img src="@_profileAvatarUrl" alt="Avatar" class="pe-avatar-img" />
                        }
                        else
                        {
                            <div class="pe-avatar-placeholder">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                    <circle cx="12" cy="8" r="4"/>
                                    <path d="M4 20c0-4 4-7 8-7s8 3 8 7"/>
                                </svg>
                            </div>
                        }
                    </div>
                    <div class="pe-avatar-controls">
                        <input type="text" @bind="_profileAvatarUrl" placeholder="Avatar image URL..." class="form-control" />
                        <label class="pe-upload-label" style="display: none;">
                            📷 Upload
                            <InputFile OnChange="HandleAvatarUpload" accept="image/*" style="display:none" />
                        </label>
                    </div>
                </div>

                <!-- Display Name -->
                <input type="text" @bind="_profileDisplayName" class="pe-name-input" placeholder="Display Name" />

                <!-- Bio -->
                <textarea @bind="_profileBio" class="pe-bio-input" rows="2" placeholder="A short bio description ..."></textarea>

                @if (_userProgress != null)
                {
                    <!-- Progress -->
                    <section class="admin-card" style="margin-bottom:1rem;padding:1rem;border-radius:16px;border:1px solid var(--border-color, rgba(255,255,255,0.12));background:rgba(255,255,255,0.04)">
                        <div style="display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap;margin-bottom:0.9rem">
                            <div>
                                <h2 style="margin:0;font-size:1.1rem">My Progress</h2>
                                <p class="muted" style="margin:0.25rem 0 0">Track your level, XP and daily streak.</p>
                            </div>
                        </div>

                        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:0.75rem">
                            <div style="padding:0.85rem;border-radius:14px;border:1px solid rgba(255,255,255,0.12);background:rgba(255,255,255,0.05);text-align:center">
                                <div style="font-size:1.4rem">🔥</div>
                                <strong style="display:block;font-size:1.25rem">@_userProgress.CurrentStreakDays</strong>
                                <span class="muted">Streak</span>
                            </div>

                            <div style="padding:0.85rem;border-radius:14px;border:1px solid rgba(255,255,255,0.12);background:rgba(255,255,255,0.05);text-align:center">
                                <div style="font-size:1.4rem">⭐</div>
                                <strong style="display:block;font-size:1.25rem">@_userProgress.Level</strong>
                                <span class="muted">Level</span>
                            </div>

                            <div style="padding:0.85rem;border-radius:14px;border:1px solid rgba(255,255,255,0.12);background:rgba(255,255,255,0.05);text-align:center">
                                <div style="font-size:1.4rem">⚡</div>
                                <strong style="display:block;font-size:1.25rem">@_userProgress.TotalXp</strong>
                                <span class="muted">XP</span>
                            </div>

                            <div style="padding:0.85rem;border-radius:14px;border:1px solid rgba(255,255,255,0.12);background:rgba(255,255,255,0.05);text-align:center">
                                <div style="font-size:1.4rem">📅</div>
                                <strong style="display:block;font-size:1.25rem">@FormatShortDate(_userProgress.LastActivityDate)</strong>
                                <span class="muted">Last Activity</span>
                            </div>
                        </div>

                        <div style="margin-top:1rem;padding:0.85rem;border-radius:14px;border:1px solid rgba(255,255,255,0.12);background:rgba(255,255,255,0.04)">
                            <div style="display:flex;justify-content:space-between;gap:1rem;font-size:0.85rem;margin-bottom:0.45rem">
                                <span>Level @_userProgress.Level → @(_userProgress.Level + 1)</span>
                                <span>@_adminCurrentLevelXp / @_adminNextLevelXp XP</span>
                            </div>

                            <div style="height:8px;border-radius:999px;background:rgba(255,255,255,0.12);overflow:hidden">
                                <div style="height:100%;width:@_adminProgressWidth;border-radius:999px;background:var(--primary, #8b5cf6)"></div>
                            </div>
                        </div>
                    </section>
                }

                <!-- Links -->
                <div class="pe-links">
                    @if (_editableLinks != null)
                    {
                        @foreach (var group in GetGroupedLinks())
                        {
                            @if (!string.IsNullOrEmpty(group.Key))
                            {
                                <div class="pe-category-label">@group.Key</div>
                            }
                            @foreach (var link in group.Value)
                            {
                                <div class="pe-link-card @(link.IsEditing ? "pe-link-editing" : "")">
                                    <div class="pe-link-row">
                                        <!-- Sort -->
                                        <div class="pe-link-sort-actions" role="group" aria-label="Reorder @link.Name">
                                            <button class="pe-link-action" @onclick="() => MoveLinkUp(link)" disabled="@IsFirstInGroup(link)" aria-label="Move @link.Name up">
                                                ▲
                                            </button>
                                            <button class="pe-link-action" @onclick="() => MoveLinkDown(link)" disabled="@IsLastInGroup(link)" aria-label="Move @link.Name down">
                                                ▼
                                            </button>
                                        </div>

                                        <!-- Icon -->
                                        <div class="@(link.IsEditing ? "pe-link-icon-btn" : "pe-link-icon-static")" @onclick="() => { if (link.IsEditing) ToggleLinkIconGrid(link); else ToggleEditLink(link); }" title="@(link.IsEditing ? "Change icon" : "")">
                                            @if (!string.IsNullOrWhiteSpace(link.Icon))
                                            {
                                                <img src="@link.Icon" alt="" />
                                            }
                                            else
                                            {
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
                                                    <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                                                    <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
                                                </svg>
                                            }
                                        </div>

                                        <!-- Name -->
                                        <div class="pe-link-name" @onclick="() => { if (!link.IsEditing) ToggleEditLink(link); }">
                                            @if (link.IsEditing)
                                            {
                                                <input type="text" @bind="link.Name" class="pe-link-name-input" placeholder="Link name" />
                                            }
                                            else
                                            {
                                                <span>@link.Name</span>
                                                @if (!string.IsNullOrWhiteSpace(link.Description))
                                                {
                                                    <span class="pe-link-desc">@link.Description</span>
                                                }
                                            }
                                        </div>

                                        <!-- Toggles -->
                                        @if (link.IsActivityPub)
                                        {
                                            <label class="pe-toggle" title="@(link.AutoBoost ? "AutoBoost ON" : "AutoBoost OFF")">
                                                <input type="checkbox" checked="@link.AutoBoost" @onchange="() => ToggleAutoBoost(link)" />
                                                <span class="pe-toggle-badge @(link.AutoBoost ? "pe-toggle-on" : "")">BOOSTED</span>
                                            </label>
                                        }
                                        <label class="pe-toggle" title="@(link.Hidden ? "Hidden" : "Visible")">
                                            <input type="checkbox" checked="@link.Hidden" @onchange="() => ToggleHidden(link)" />
                                            <span class="pe-toggle-badge pe-toggle-hidden @(link.Hidden ? "pe-toggle-on" : "")">HIDDEN</span>
                                        </label>

                                        <!-- Actions -->
                                        <button class="pe-link-action" @onclick="() => ToggleEditLink(link)" title="@(link.IsEditing ? "Close editor" : "Edit link")" aria-label="@(link.IsEditing ? "Close editor for " + link.Name : "Edit " + link.Name)">
                                            @(link.IsEditing ? "✕" : "✏️")
                                        </button>
                                        <button class="pe-link-action pe-link-delete" @onclick="() => DeleteLinkById(link.Id)" title="Delete" aria-label="Delete @link.Name">
                                            🗑️
                                        </button>
                                    </div>

                                    <!-- Icon Grid -->
                                    @if (link.IconGridOpen)
                                    {
                                        <div class="pe-icon-grid">
                                            <div class="pe-icon-grid-item @(string.IsNullOrEmpty(link.SelectedIconKey) ? "pe-icon-selected" : "")"
                                                 @onclick="() => SelectLinkIcon(link, null)">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="28" height="28">
                                                    <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                                                    <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
                                                </svg>
                                                <small>None</small>
                                            </div>
                                            @foreach (var icon in _platformIcons)
                                            {
                                                <div class="pe-icon-grid-item @(link.SelectedIconKey == icon.Key ? "pe-icon-selected" : "")"
                                                     @onclick="() => SelectLinkIcon(link, icon.Key)">
                                                    <img src="/assets/icons/@(icon.Key).svg" alt="" />
                                                    <small>@icon.Value.Name</small>
                                                </div>
                                            }
                                            <div class="pe-icon-grid-item @(link.SelectedIconKey == "__favicon__" ? "pe-icon-selected" : "")"
                                                 @onclick="() => FetchFaviconForLink(link)"
                                                 title="Fetch favicon from link URL">
                                                <span style="font-size:1.4rem">📎</span>
                                                <small>Favicon</small>
                                            </div>
                                            <div class="pe-icon-grid-item @(link.SelectedIconKey == "__custom__" ? "pe-icon-selected" : "")"
                                                 @onclick='() => SelectLinkIcon(link, "__custom__")'>
                                                <span style="font-size:1.4rem">🌐</span>
                                                <small>Custom</small>
                                            </div>
                                            @if (link.SelectedIconKey == "__custom__" || link.SelectedIconKey == "__favicon__")
                                            {
                                                <div class="pe-icon-grid-custom">
                                                    <input type="text" @bind="link.CustomIconUrl" @bind:after="() => ApplyCustomIcon(link)"
                                                           placeholder="https://example.com/icon.svg" class="form-control" />
                                                </div>
                                            }
                                        </div>
                                    }

                                    <!-- Expanded edit fields -->
                                    @if (link.IsEditing)
                                    {
                                        <div class="pe-link-edit-fields">
                                            <div class="form-group">
                                                <label>URL</label>
                                                <input type="text" @bind="link.Url" placeholder="https://example.com" class="form-control" />
                                                @{ var _editHint = GetEditLinkUrlHint(link); }
                                                @if (_editHint != null)
                                                {
                                                    <small class="alert alert-warning" style="display:block;margin-top:0.35rem;padding:0.4rem 0.6rem;font-size:0.82rem">
                                                        @_editHint
                                                    </small>
                                                }
                                            </div>
                                            <div class="form-group">
                                                <label>Description</label>
                                                <input type="text" @bind="link.Description" placeholder="A short description (optional)" class="form-control" />
                                            </div>
                                            <div class="form-group">
                                                <label>Category</label>
                                                <select @bind="link.Category" class="form-control">
                                                    <option value="">— None —</option>
                                                    @foreach (var cat in _availableCategories)
                                                    {
                                                        <option value="@cat">@cat</option>
                                                    }
                                                    <option value="__custom__">+ Add custom…</option>
                                                </select>
                                                @if (link.Category == "__custom__")
                                                {
                                                    <input type="text" @bind="link.CustomCategory"
                                                           placeholder="Enter custom category" class="form-control admin-mt-sm" />
                                                }
                                            </div>
                                            <div class="pe-link-edit-actions">
                                                <button class="button button-primary button-small" @onclick="() => SaveLinkInline(link)">
                                                    Save Link
                                                </button>
                                                <button class="button button-ghost button-small" @onclick="() => CancelEditLink(link)">
                                                    Cancel
                                                </button>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        }
                    }

                    <!-- Add new link -->
                    @if (!_addingNewLink)
                    {
                        <button class="pe-add-link-btn" @onclick="StartAddingLink">
                            + Add a link
                        </button>
                    }
                    else
                    {
                        <div class="pe-link-card pe-link-editing pe-link-new">
                            <div class="pe-link-row">
                                <div class="pe-link-icon-btn" @onclick="ToggleNewLinkIconGrid" title="Choose icon">
                                    @if (!string.IsNullOrWhiteSpace(ResolveNewLinkIcon()))
                                    {
                                        <img src="@ResolveNewLinkIcon()" alt="" />
                                    }
                                    else
                                    {
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
                                            <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                                            <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
                                        </svg>
                                    }
                                </div>
                                <div class="pe-link-name" style="flex:1">
                                    <input type="text" @bind="_newLinkName" class="pe-link-name-input" placeholder="Link name" />
                                </div>
                                <label class="pe-toggle" title="Hidden">
                                    <input type="checkbox" @bind="_newLinkHidden" />
                                    <span class="pe-toggle-badge pe-toggle-hidden @(_newLinkHidden ? "pe-toggle-on" : "")">HIDDEN</span>
                                </label>
                            </div>

                            @if (_newLinkIconGridOpen)
                            {
                                <div class="pe-icon-grid">
                                    <div class="pe-icon-grid-item @(string.IsNullOrEmpty(_selectedIconKey) ? "pe-icon-selected" : "")"
                                         @onclick="() => SelectIcon(null)">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="28" height="28">
                                            <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                                            <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
                                        </svg>
                                        <small>None</small>
                                    </div>
                                    @foreach (var icon in _platformIcons)
                                    {
                                        <div class="pe-icon-grid-item @(_selectedIconKey == icon.Key ? "pe-icon-selected" : "")"
                                             @onclick="() => SelectIcon(icon.Key)">
                                            <img src="/assets/icons/@(icon.Key).svg" alt="" />
                                            <small>@icon.Value.Name</small>
                                        </div>
                                    }
                                    <div class="pe-icon-grid-item @(_selectedIconKey == "__favicon__" ? "pe-icon-selected" : "")"
                                         @onclick="FetchFaviconForNewLink"
                                         title="Fetch favicon from link URL">
                                        <span style="font-size:1.4rem">📎</span>
                                        <small>Favicon</small>
                                    </div>
                                    <div class="pe-icon-grid-item @(_selectedIconKey == "__custom__" ? "pe-icon-selected" : "")"
                                         @onclick='() => SelectIcon("__custom__")'>
                                        <span style="font-size:1.4rem">🌐</span>
                                        <small>Custom</small>
                                    </div>
                                    @if (_selectedIconKey == "__custom__" || _selectedIconKey == "__favicon__")
                                    {
                                        <div class="pe-icon-grid-custom">
                                            <input type="text" @bind="_customIconUrl"
                                                   placeholder="https://example.com/icon.svg" class="form-control" />
                                        </div>
                                    }
                                </div>
                            }

                            <div class="pe-link-edit-fields">
                                <div class="form-group">
                                    <label>URL</label>
                                    <input type="text" @bind="_newLinkUrl" placeholder="https://example.com" class="form-control" />
                                    @{ var _newLinkHint = GetNewLinkUrlHint(); }
                                    @if (_newLinkHint != null)
                                    {
                                        <small class="alert alert-warning" style="display:block;margin-top:0.35rem;padding:0.4rem 0.6rem;font-size:0.82rem">
                                            @_newLinkHint
                                        </small>
                                    }
                                </div>
                                <div class="form-group">
                                    <label>Description (optional)</label>
                                    <input type="text" @bind="_newLinkDescription" placeholder="A short description" class="form-control" />
                                </div>
                                <div class="form-group">
                                    <label>Category</label>
                                    <select @bind="_newLinkCategory" class="form-control">
                                        <option value="">— None —</option>
                                        @foreach (var cat in _availableCategories)
                                        {
                                            <option value="@cat">@cat</option>
                                        }
                                        <option value="__custom__">+ Add custom…</option>
                                    </select>
                                    @if (_newLinkCategory == "__custom__")
                                    {
                                        <input type="text" @bind="_customCategory"
                                               placeholder="Enter custom category" class="form-control admin-mt-sm" />
                                    }
                                </div>
                                <div class="pe-link-edit-actions">
                                    <button class="button button-primary button-small" @onclick="AddLink" disabled="@_isProcessing">
                                        Add Link
                                    </button>
                                    <button class="button button-ghost button-small" @onclick="CancelAddingLink">
                                        Cancel
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                @if (!string.IsNullOrEmpty(_linkMessage))
                {
                    <div class="alert @(_linkIsError ? "alert-error" : "alert-success")" style="margin-top:1rem">
                        @_linkMessage
                    </div>
                }

                <!-- Fedi handle info -->
                <div class="pe-info-section">
                    <p class="muted">Follow me in the fediverse: @@<strong>@_currentUserSlug@@@(_currentDomain)</strong></p>
                    <p class="muted" style="font-size:0.82rem">Not in the fediverse? <a href="https://joinmastodon.org" target="_blank" style="text-decoration:underline">Join now </a></p>
                </div>

                <!-- Footer: Save -->
                <div class="pe-save-bar">
                    <div style="display:flex;align-items:center;gap:0.5rem;margin-left:auto">
                        <a href="/@_currentUserSlug" target="_blank" class="button button-ghost button-small">Preview ↗</a>
                        <button class="button button-primary" @onclick="SaveProfile" disabled="@_isProcessing">
                            @(_isProcessing ? "Saving..." : "Save Profile")
                        </button>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(_profileMessage))
                {
                    <div class="alert @(_profileIsError ? "alert-error" : "alert-success")">
                        @_profileMessage
                    </div>
                }
            </article>

            <!-- Missions -->
            @if (_userMissions.Count > 0)
            {
                <article class="card admin-card-spaced admin-missions-card">
                    <div class="admin-missions-header">
                        <div>
                            <h2 class="admin-missions-title">🎯 Missions</h2>
                            <p class="admin-missions-subtitle">
                                Complete profile challenges, earn XP, and unlock progress.
                            </p>
                        </div>

                        <div class="admin-missions-summary">
                            <strong>@_completedMissionsCount / @_totalMissionsCount</strong>
                            <span>completed</span>
                        </div>
                    </div>

                    <div class="admin-missions-progress">
                        <div class="admin-missions-progress-fill" style="width:@_missionsProgressWidth"></div>
                    </div>

                    @foreach (var category in MissionCategoryOrder)
                    {
                        var categoryMissions = _userMissions
                            .Where(m => m.Category == category)
                            .ToList();

                        if (categoryMissions.Count == 0)
                        {
                            continue;
                        }

                        <div class="admin-mission-category">
                            <div class="admin-mission-category-heading">
                                <span>@GetMissionCategoryIcon(category)</span>
                                <h3>@category</h3>
                            </div>

                            <div class="admin-mission-grid">
                                @foreach (var mission in categoryMissions)
                                {
                                    <article class="admin-mission-card @(mission.IsCompleted ? "admin-mission-completed" : "admin-mission-pending")" @key="mission.Code">
                                        <div class="admin-mission-icon">
                                            @mission.Icon
                                        </div>

                                        <div class="admin-mission-content">
                                            <h4>@mission.Title</h4>

                                            <p>@mission.Description</p>

                                            <div class="admin-mission-footer">
                                                <span class="admin-mission-xp">
                                                    +@mission.XpReward XP
                                                </span>

                                                @if (mission.IsCompleted)
                                                {
                                                    <span class="admin-mission-status admin-mission-status-completed">
                                                        ✅ Completed
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="admin-mission-status admin-mission-status-pending">
                                                        ⏳ Pending
                                                    </span>
                                                }
                                            </div>
                                        </div>
                                    </article>
                                }
                            </div>
                        </div>
                    }
                </article>
            }

            <!-- Community Overview -->
            <article class="card admin-card-spaced admin-community-card">
                <div class="admin-community-header">
                    <div>
                        <h2 class="admin-community-title">🌐 Community</h2>
                        <p class="admin-community-subtitle">
                            Overview of your profile's social presence across the Fediverse.
                        </p>
                    </div>

                    <div class="admin-community-status">
                        <strong>@CommunityStatusLabel</strong>
                        <span>@CommunityTotalSignals signals</span>
                    </div>
                </div>

                <div class="admin-community-handle">
                    <div>
                        <span class="admin-community-handle-label">Fediverse handle</span>
                        <code>@FediverseHandle</code>
                    </div>

                    <button class="button button-ghost button-small" @onclick="CopyFediverseHandle">
                        @(_fediverseHandleCopied ? "Copied!" : "Copy handle")
                    </button>
                </div>

                <div class="admin-community-grid">
                    <div class="admin-community-stat">
                        <div class="admin-community-stat-icon">👥</div>
                        <div>
                            <strong>@CommunityFollowersCount</strong>
                            <span>Followers</span>
                            <p>People following your federated profile.</p>
                        </div>
                    </div>

                    <div class="admin-community-stat">
                        <div class="admin-community-stat-icon">🏅</div>
                        <div>
                            <strong>@CommunityBadgeSourcesCount</strong>
                            <span>Badge sources</span>
                            <p>Issuers connected through received badges.</p>
                        </div>
                    </div>

                    <div class="admin-community-stat">
                        <div class="admin-community-stat-icon">🛰️</div>
                        <div>
                            <strong>@CommunityFediverseLinksCount</strong>
                            <span>Fediverse links</span>
                            <p>ActivityPub links detected in your profile.</p>
                        </div>
                    </div>

                    <div class="admin-community-stat">
                        <div class="admin-community-stat-icon">📢</div>
                        <div>
                            <strong>@CommunityRecentActivityCount</strong>
                            <span>Recent activity</span>
                            <p>Recent posts available for your profile.</p>
                        </div>
                    </div>
                </div>
            </article>

            <!-- Followers -->
            @if (_followers != null)
            {
                <article class="card admin-card-spaced">
                    <h2>Followers (@_followerCount)</h2>
                    <p class="muted">People following your profile via ActivityPub</p>

                    @if (_followerCount == 0)
                    {
                        <p class="text-muted">No followers yet.</p>
                    }
                    else
                    {
                        <table class="user-table">
                            <thead>
                                <tr>
                                    <th>Actor</th>
                                    <th>Domain</th>
                                    <th>Followed</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var f in _followers.Take(50))
                                {
                                    <tr>
                                        <td>
                                            @if (!string.IsNullOrEmpty(f.AvatarUri))
                                            {
                                                <img src="@f.AvatarUri" alt="" style="width:24px;height:24px;border-radius:50%;vertical-align:middle;margin-right:0.4rem;" />
                                            }
                                            <a href="@f.FollowerUri" target="_blank" rel="noopener">@(f.DisplayName ?? f.FollowerUri)</a>
                                        </td>
                                        <td>@f.Domain</td>
                                        <td>@f.CreatedUtc</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        @if (_followerCount > 10)
                        {
                            <p class="text-muted" style="margin-top:0.5rem;">Showing newest 10 of @_followerCount followers.</p>
                        }
                    }
                </article>
            }

            <!-- Badges & Verifications -->
            <article class="card admin-card-spaced">
                <div style="margin-bottom:0.75rem">
                    <h2 style="margin:0">🏅 Badges</h2>
                    <p class="muted" style="margin:0.25rem 0 0">Badges you've earned and received</p>
                </div>

                <div style="display:flex;gap:0;border-bottom:2px solid var(--border, #ddd);margin-bottom:1rem">
                    <button class="button button-ghost button-small" style="border-radius:6px 6px 0 0;border-bottom:2px solid @(_badgeTab == "badges" ? "var(--primary, #7c3aed)" : "transparent");margin-bottom:-2px;font-weight:@(_badgeTab == "badges" ? "600" : "400")" @onclick="ShowBadgesTab">
                        🏅 My Badges
                    </button>
                    <button class="button button-ghost button-small" style="border-radius:6px 6px 0 0;border-bottom:2px solid @(_badgeTab == "import" ? "var(--primary, #7c3aed)" : "transparent");margin-bottom:-2px;font-weight:@(_badgeTab == "import" ? "600" : "400")" @onclick="ShowImportTab">
                        ⬇️ Import
                    </button>
                    <button class="button button-ghost button-small" style="border-radius:6px 6px 0 0;border-bottom:2px solid @(_badgeTab == "issuers" ? "var(--primary, #7c3aed)" : "transparent");margin-bottom:-2px;font-weight:@(_badgeTab == "issuers" ? "600" : "400")" @onclick="ShowIssuersTab">
                        🔑 Issuers
                    </button>
                    <button class="button button-ghost button-small" style="border-radius:6px 6px 0 0;border-bottom:2px solid @(_badgeTab == "verified" ? "var(--primary, #7c3aed)" : "transparent");margin-bottom:-2px;font-weight:@(_badgeTab == "verified" ? "600" : "400")" @onclick="ShowVerifiedTab">
                        ✅ Verified URIs
                    </button>
                </div>

                <!-- Import Badge tab -->
                @if (_badgeTab == "import")
                {
                    <div style="margin-top:1rem;padding:1rem;border:1px solid var(--border, #ddd);border-radius:8px;background:var(--bg-subtle, #f8f9fa)">
                        <h3 style="margin:0 0 0.25rem">Import a Badge</h3>
                        <p class="muted" style="margin:0 0 0.75rem">Paste a BadgeFed grant URL to import</p>

                        @if (!string.IsNullOrEmpty(_importBadgeMessage))
                        {
                            <div class="alert @(_importBadgeIsError ? "alert-error" : "alert-success")" style="margin-bottom:0.75rem">
                                @_importBadgeMessage
                            </div>
                        }

                        <div style="display:flex;gap:0.5rem;align-items:center">
                            <input type="text" @bind="_importBadgeUrl" placeholder="https://badgefed.org/view/grant/..." class="form-control" style="flex:1" />
                            <button class="button button-primary" @onclick="ImportBadge" disabled="@(_isImportingBadge || string.IsNullOrWhiteSpace(_importBadgeUrl))">
                                @(_isImportingBadge ? "Importing..." : "Import")
                            </button>
                        </div>
                    </div>
                }

                <!-- Badge Issuers tab -->
                @if (_badgeTab == "issuers")
                {
                    <div style="margin-top:1rem;padding:1rem;border:1px solid var(--border, #ddd);border-radius:8px;background:var(--bg-subtle, #f8f9fa)">
                        <h3 style="margin:0 0 0.75rem">Trusted Badge Issuers</h3>

                        @if (_badgeIssuers == null)
                        {
                            <p class="muted">Loading issuers...</p>
                        }
                        else if (!_badgeIssuers.Any())
                        {
                            <p class="muted">No badge issuers yet. Import a badge to see issuers here.</p>
                        }
                        else
                        {
                            <div style="display:flex;flex-direction:column;gap:0.75rem">
                                @foreach (var issuer in _badgeIssuers)
                                {
                                    <div style="display:flex;align-items:center;gap:0.75rem;padding:0.5rem;border-radius:6px;background:var(--bg, #fff)">
                                        @if (!string.IsNullOrEmpty(issuer.Avatar))
                                        {
                                            <img src="@issuer.Avatar" alt="@issuer.Name" style="width:36px;height:36px;border-radius:50%;object-fit:cover;flex-shrink:0" />
                                        }
                                        else
                                        {
                                            <div style="width:36px;height:36px;border-radius:50%;background:var(--border, #ddd);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:1rem">🔑</div>
                                        }
                                        <div style="min-width:0;flex:1">
                                            <div style="font-weight:600">@issuer.Name</div>
                                            <a href="@issuer.ActorUrl" target="_blank" rel="noopener" style="font-size:0.8rem;color:var(--muted);word-break:break-all">@TruncateUrl(issuer.ActorUrl)</a>
                                        </div>
                                        @if (issuer.Following)
                                        {
                                            <span style="font-size:0.75rem;padding:2px 8px;border-radius:9999px;background:#4caf50;color:#fff;white-space:nowrap">Following</span>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }

                <!-- Verified URIs tab -->
                @if (_badgeTab == "verified")
                {
                    <div style="margin-top:1rem;padding:1rem;border:1px solid var(--border, #ddd);border-radius:8px;background:var(--bg-subtle, #f8f9fa)">
                        <h3 style="margin:0 0 0.75rem">
                            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle;margin-right:4px;color:#4caf50"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>Verified URIs
                        </h3>

                        @if (_verifiedUris == null)
                        {
                            <p class="muted">Loading verified URIs...</p>
                        }
                        else if (!_verifiedUris.Any())
                        {
                            <p class="muted">No verified URIs yet.</p>
                        }
                        else
                        {
                            <div style="display:flex;flex-direction:column;gap:0.5rem">
                                @foreach (var uri in _verifiedUris)
                                {
                                    <div style="display:flex;align-items:center;gap:0.5rem;padding:0.4rem 0.5rem;border-radius:6px;background:var(--bg, #fff)">
                                        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="#4caf50" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
                                        <a href="@uri.Uri" target="_blank" rel="noopener" style="flex:1;word-break:break-all;font-size:0.9rem">@TruncateUrl(uri.Uri)</a>
                                        <span class="muted" style="font-size:0.75rem;white-space:nowrap">@uri.VerifiedUtc</span>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }

                <!-- Received Badges tab (default) -->
                @if (_badgeTab == "badges")
                {
                <div>
                    @if (_receivedBadges == null)
                    {
                        <p class="muted">Loading badges...</p>
                    }
                    else if (!_receivedBadges.Any())
                    {
                        <div style="text-align:center;padding:2rem 1rem;color:var(--muted)">
                            <div style="font-size:2.5rem;margin-bottom:0.5rem">🏅</div>
                            <p style="margin:0">No badges yet. Import one to get started!</p>
                        </div>
                    }
                    else
                    {
                        <div style="display:grid;grid-template-columns:repeat(auto-fill, minmax(220px, 1fr));gap:0.75rem">
                            @foreach (var badge in _receivedBadges)
                            {
                                var issuer = _badgeIssuers?.FirstOrDefault(i => i.Id == badge.IssuerId);
                                <div style="border:1px solid var(--border, #ddd);border-radius:10px;overflow:hidden;transition:opacity 0.2s;@(badge.Hidden ? "opacity:0.45;" : "")">
                                    @if (!string.IsNullOrEmpty(badge.Image))
                                    {
                                        <div style="background:var(--bg-subtle, #f0f0f0);display:flex;align-items:center;justify-content:center;padding:0.75rem">
                                            <img src="@badge.Image" alt="@badge.Title" style="max-width:100%;max-height:100px;object-fit:contain;border-radius:6px" />
                                        </div>
                                    }
                                    else
                                    {
                                        <div style="background:var(--bg-subtle, #f0f0f0);display:flex;align-items:center;justify-content:center;padding:1rem;font-size:2.5rem">
                                            🏅
                                        </div>
                                    }
                                    <div style="padding:0.75rem">
                                        <div style="font-weight:700;font-size:0.95rem;margin-bottom:0.25rem">@badge.Title</div>
                                        @if (issuer != null)
                                        {
                                            <div style="font-size:0.8rem;color:var(--muted);margin-bottom:0.25rem">
                                                by @issuer.Name
                                            </div>
                                        }
                                        @if (!string.IsNullOrEmpty(badge.IssuedOn))
                                        {
                                            <div style="font-size:0.75rem;color:var(--muted)">Issued: @badge.IssuedOn</div>
                                        }
                                        <div style="display:flex;gap:0.45rem;flex-wrap:wrap;margin-top:0.75rem">
                                            <button class="button button-ghost button-small"
                                                    style="font-size:0.75rem;padding:2px 8px"
                                                    @onclick="() => ToggleFeaturedBadge(badge)"
                                                    title="@(badge.IsFeatured ? "Remove from featured badges" : "Show as featured badge")">
                                                @(badge.IsFeatured ? "⭐ Featured" : "☆ Feature")
                                            </button>

                                            <button class="button button-ghost button-small"
                                                    style="font-size:0.75rem;padding:2px 8px"
                                                    @onclick="() => ToggleBadgeVisibility(badge)"
                                                    title="@(badge.Hidden ? "Show on profile" : "Hide from profile")">
                                                @(badge.Hidden ? "👁️ Show" : "🙈 Hide")
                                            </button>

                                            @if (!string.IsNullOrWhiteSpace(badge.NoteId))
                                            {
                                                <a class="button button-ghost button-small"
                                                style="font-size:0.75rem;padding:2px 8px"
                                                href="@badge.NoteId"
                                                target="_blank"
                                                rel="noopener noreferrer"
                                                title="View badge">
                                                    🔗 View
                                                </a>
                                            }

                                            @if (_badgeDeleteConfirmId == badge.Id)
                                            {
                                                <button type="button"
                                                        class="button button-danger button-small"
                                                        style="font-size:0.75rem;padding:2px 8px"
                                                        @onclick="() => DeleteBadge(badge.Id)"
                                                        title="Confirm delete badge">
                                                    Delete
                                                </button>

                                                <button type="button"
                                                        class="button button-ghost button-small"
                                                        style="font-size:0.75rem;padding:2px 8px"
                                                        @onclick="() => _badgeDeleteConfirmId = null"
                                                        title="Cancel delete">
                                                    Cancel
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="button"
                                                        class="button button-ghost button-small"
                                                        style="font-size:0.75rem;padding:2px 8px"
                                                        @onclick="() => _badgeDeleteConfirmId = badge.Id"
                                                        title="Delete badge">
                                                    🗑
                                                </button>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
                }
            </article>

            <!-- Recent Posts -->
            <article class="card admin-card-spaced">
                <h2>Recent Posts (@(_recentPosts?.Count ?? 0))</h2>
                <p class="muted">The last boosted posts from your linked accounts. These are shown on your public profile.</p>

                @if (_recentPosts == null)
                {
                    <p class="muted">Loading…</p>
                }
                else if (!_recentPosts.Any())
                {
                    <div style="padding:1.25rem;border:1px dashed var(--border, #d0d0d0);border-radius:10px;background:var(--bg-subtle, #f8f9fa);text-align:center">
                        <p style="font-size:0.95rem;font-weight:600;margin:0 0 0.4rem">Want to show your latest posts and activity?</p>
                        <p class="muted" style="font-size:0.85rem;margin:0 0 0.6rem;line-height:1.5">
                            Add a fediverse account — such as <strong>Mastodon</strong>, <strong>Pixelfed</strong>, or <strong>Misskey</strong> — as a link with <em>AutoBoost</em> enabled.<br />
                            Your recent posts will then appear here and on your public profile automatically.
                        </p>
                        <p class="muted" style="font-size:0.8rem;margin:0">Head to the <strong>Links</strong> section above to add one.</p>
                        <p class="muted" style="font-size:0.8rem;margin:0.5rem 0 0">Unsure where to start? <a href="https://joinmastodon.org" target="_blank" rel="noopener">Join Mastodon ↗</a></p>
                    </div>
                }
                else
                {
                    <div style="display:flex;flex-direction:column;gap:0.75rem;margin-top:0.75rem">
                        @foreach (var post in _recentPosts)
                        {
                            <div style="border:1px solid var(--border, #e0e0e0);border-radius:8px;padding:0.75rem;background:var(--bg-subtle, #f8f9fa)">
                                <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.4rem">
                                    @if (!string.IsNullOrEmpty(post.ActorAvatar))
                                    {
                                        <img src="@post.ActorAvatar" alt="" style="width:24px;height:24px;border-radius:50%;object-fit:cover" />
                                    }
                                    <strong style="font-size:0.9rem">@(post.ActorName ?? post.ActorUri)</strong>
                                    @if (!string.IsNullOrEmpty(post.PublishedUtc))
                                    {
                                        <span class="muted" style="font-size:0.78rem;margin-left:auto" title="@post.PublishedUtc">@FormatPostDate(post.PublishedUtc)</span>
                                    }
                                </div>
                                @if (!string.IsNullOrEmpty(post.Content))
                                {
                                    <div style="font-size:0.88rem;line-height:1.45;overflow:hidden;max-height:6rem">@((MarkupString)post.Content)</div>
                                }
                                else if (!string.IsNullOrEmpty(post.Summary))
                                {
                                    <p style="font-size:0.88rem;line-height:1.45" class="muted">@post.Summary</p>
                                }
                                @if (!string.IsNullOrEmpty(post.Url))
                                {
                                    <a href="@post.Url" target="_blank" rel="noopener" style="font-size:0.8rem;margin-top:0.3rem;display:inline-block">View original ↗</a>
                                }
                            </div>
                        }
                    </div>
                }
            </article>

            <!-- Settings -->
            <article class="card admin-card-spaced">
                <h2>Settings</h2>
                <p class="muted">Configure how your profile behaves.</p>

                <div style="margin-top:0.75rem;display:flex;flex-direction:column;gap:1rem">
                    <!-- Skip Replies -->
                    <div style="display:flex;align-items:flex-start;gap:0.75rem;padding:0.75rem;border:1px solid var(--border, #e0e0e0);border-radius:8px;background:var(--bg-subtle, #f8f9fa)">
                        <label class="pe-toggle" style="flex-shrink:0;margin-top:0.1rem;cursor:pointer" title="@(_profileSkipReplies ? "Only boosting main posts" : "Boosting all posts including replies")">
                            <input type="checkbox" checked="@_profileSkipReplies" @onchange="OnSkipRepliesChanged" />
                            <span class="pe-toggle-badge @(_profileSkipReplies ? "pe-toggle-on" : "")">@(_profileSkipReplies ? "ON" : "OFF")</span>
                        </label>
                        <div>
                            <strong style="font-size:0.92rem">Skip Replies</strong>
                            <p class="muted" style="font-size:0.82rem;margin:0.15rem 0 0">Only boost original/main posts. When enabled, replies from your linked accounts will not be announced to your followers.</p>
                        </div>
                    </div>

                    <!-- Show Recent Posts -->
                    <div style="display:flex;align-items:flex-start;gap:0.75rem;padding:0.75rem;border:1px solid var(--border, #e0e0e0);border-radius:8px;background:var(--bg-subtle, #f8f9fa)">
                        <label class="pe-toggle" style="flex-shrink:0;margin-top:0.1rem;cursor:pointer" title="@(_profileShowRecentPosts ? "Recent posts visible on public profile" : "Recent posts hidden from public profile")">
                            <input type="checkbox" checked="@_profileShowRecentPosts" @onchange="OnShowRecentPostsChanged" />
                            <span class="pe-toggle-badge @(_profileShowRecentPosts ? "pe-toggle-on" : "")">@(_profileShowRecentPosts ? "ON" : "OFF")</span>
                        </label>
                        <div>
                            <strong style="font-size:0.92rem">Show Recent Posts</strong>
                            <p class="muted" style="font-size:0.82rem;margin:0.15rem 0 0">Display recently boosted posts on your public profile page. When disabled, the Recent Activity section is hidden from visitors.</p>
                        </div>
                    </div>
                </div>
            </article>

            <!-- Danger Zone -->
            <article class="card admin-card-spaced" style="border:2px solid #dc3545;">
                <h2 style="color:#dc3545;">⚠️ Danger Zone</h2>
                <p class="muted">Permanently delete your account and all associated data. This action cannot be undone.</p>

                @if (!string.IsNullOrEmpty(_deleteAccountMessage))
                {
                    <div class="alert @(_deleteAccountIsError ? "alert-error" : "alert-success")">
                        @_deleteAccountMessage
                    </div>
                }

                @if (!_deleteAccountConfirming)
                {
                    <button class="button button-danger" @onclick="() => _deleteAccountConfirming = true" disabled="@_isProcessing">
                        Delete My Account
                    </button>
                }
                else
                {
                    <div class="alert alert-error" style="margin-bottom:1rem;">
                        <strong>Are you sure?</strong> This will permanently delete your profile, all links, badges, and data.
                        Type your username <strong>@_currentUserSlug</strong> below to confirm.
                    </div>
                    <div class="form-group">
                        <input type="text" @bind="_deleteAccountConfirmText" placeholder="Type your username to confirm" class="form-control" />
                    </div>
                    <div style="display:flex;gap:0.5rem;margin-top:0.5rem;">
                        <button class="button button-danger" 
                                @onclick="DeleteMyAccount" 
                                disabled="@(_isProcessing || _deleteAccountConfirmText != _currentUserSlug)">
                            @(_isProcessing ? "Deleting..." : "Permanently Delete Account")
                        </button>
                        <button class="button button-ghost" @onclick="CancelDeleteAccount">
                            Cancel
                        </button>
                    </div>
                }
            </article>
        </div>
    }
</section>

<style>
    .admin-missions-card {
        overflow: hidden;
        --mission-accent: var(--primary, var(--accent, #8b5cf6));
        --mission-surface: color-mix(in srgb, currentColor 6%, transparent);
        --mission-surface-strong: color-mix(in srgb, currentColor 10%, transparent);
        --mission-border: color-mix(in srgb, currentColor 16%, transparent);
        --mission-muted: color-mix(in srgb, currentColor 62%, transparent);
    }

    .admin-missions-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
        margin-bottom: 0.85rem;
    }

    .admin-missions-title {
        margin: 0;
        font-size: 1.25rem;
        line-height: 1.2;
        color: inherit;
    }

    .admin-missions-subtitle {
        margin: 0.25rem 0 0;
        color: var(--mission-muted);
        font-size: 0.9rem;
    }

    .admin-missions-summary {
        min-width: 96px;
        padding: 0.65rem 0.8rem;
        border: 1px solid var(--mission-border);
        border-radius: 14px;
        text-align: center;
        background: var(--mission-surface);
        color: inherit;
    }

    .admin-missions-summary strong {
        display: block;
        font-size: 1rem;
        line-height: 1.1;
        color: inherit;
    }

    .admin-missions-summary span {
        display: block;
        margin-top: 0.15rem;
        font-size: 0.72rem;
        color: var(--mission-muted);
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .admin-missions-progress {
        width: 100%;
        height: 9px;
        border-radius: 999px;
        overflow: hidden;
        background: var(--mission-surface-strong);
        margin-bottom: 1.1rem;
    }

    .admin-missions-progress-fill {
        height: 100%;
        border-radius: 999px;
        background: var(--mission-accent);
        transition: width 300ms ease;
    }

    .admin-mission-category {
        margin-top: 1rem;
    }

    .admin-mission-category-heading {
        display: flex;
