    /// <summary>
    /// Checks whether a URL looks like a handle instead of a full URL for the chosen platform icon or link name.
    /// Returns (correctedUrl, warningMessage). If no correction needed both are null.
    /// </summary>
    private static (string? CorrectedUrl, string? Warning) DetectUrlHint(string? iconKey, string? url, string? linkName = null)
    {
        if (string.IsNullOrWhiteSpace(url)) return (null, null);
        var trimmed = url.Trim();

        // If it already looks like a URL, nothing to do
        if (trimmed.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
            trimmed.StartsWith("https://", StringComparison.OrdinalIgnoreCase))
            return (null, null);

        // Detect @user@domain.com webfinger format
        if (IsWebfingerHandle(trimmed))
            return (null, "This looks like a fediverse handle — it will be resolved via WebFinger and saved as the profile URL.");

        // Try to find a matching rule: first by icon key, then by link name
        (string HandlePrefix, string UrlTemplate, string PlatformName, string Example)? matched = null;

        if (!string.IsNullOrEmpty(iconKey) && _urlHints.TryGetValue(iconKey, out var hintByIcon))
        {
            matched = hintByIcon;
        }
        else if (!string.IsNullOrWhiteSpace(linkName))
        {
            foreach (var kvp in _urlHints)
            {
                if (string.Equals(kvp.Value.PlatformName, linkName.Trim(), StringComparison.OrdinalIgnoreCase))
                {
                    matched = kvp.Value;
                    break;
                }
            }
        }

        if (matched is { } hint)
        {
            if (trimmed.StartsWith(hint.HandlePrefix))
            {
                var handle = trimmed.TrimStart('@', '#');
                var corrected = string.Format(hint.UrlTemplate, handle);
                return (corrected, $"This looks like a {hint.PlatformName} handle — the URL will be saved as {corrected}");
            }
        }

        // Generic warning when nothing matched and input looks like a handle
        if (trimmed.StartsWith("@") || trimmed.StartsWith("#"))
            return (null, "This doesn't look like a URL. Select a platform icon (e.g. Bluesky, Matrix) to auto-convert handles, or enter a full URL starting with https://.");

        return (null, null);
    }

    /// <summary>Checks if the input matches the @user@domain.tld webfinger format.</summary>
    private static bool IsWebfingerHandle(string input)
    {
        if (!input.StartsWith("@")) return false;
        var withoutLeadingAt = input.Substring(1);
        var atIdx = withoutLeadingAt.IndexOf('@');
        return atIdx > 0 && atIdx < withoutLeadingAt.Length - 1 && withoutLeadingAt.Substring(atIdx + 1).Contains('.');
    }

    /// <summary>
    /// Resolves a @user@domain.tld handle via WebFinger.
    /// Returns (profileUrl, actorAPUri) or (null, null) on failure.
    /// </summary>
    private static async Task<(string? ProfileUrl, string? ActorUri)> ResolveWebfingerAsync(string handle)
    {
        var withoutLeadingAt = handle.TrimStart('@');
        var atIdx = withoutLeadingAt.IndexOf('@');
        if (atIdx <= 0) return (null, null);
        var domain = withoutLeadingAt.Substring(atIdx + 1);

        var webfingerUrl = $"https://{domain}/.well-known/webfinger?resource=acct:{withoutLeadingAt}";

        using var http = new HttpClient { Timeout = TimeSpan.FromSeconds(10) };
        http.DefaultRequestHeaders.Add("Accept", "application/jrd+json, application/json");
        var resp = await http.GetAsync(webfingerUrl);
        resp.EnsureSuccessStatusCode();

        var json = await resp.Content.ReadAsStringAsync();
        using var doc = System.Text.Json.JsonDocument.Parse(json);

        string? profileUrl = null;
        string? actorUri = null;

        if (doc.RootElement.TryGetProperty("links", out var links))
        {
            foreach (var link in links.EnumerateArray())
            {
                var rel = link.TryGetProperty("rel", out var r) ? r.GetString() : null;
                var type = link.TryGetProperty("type", out var t) ? t.GetString() : null;
                var href = link.TryGetProperty("href", out var h) ? h.GetString() : null;
                if (string.IsNullOrEmpty(href)) continue;

                if (rel == "self" && type != null && type.Contains("activity"))
                    actorUri = href;
                else if (rel == "http://webfinger.net/rel/profile-page")
                    profileUrl = href;
            }
        }

        // Use actor URI as profile URL fallback
        return (profileUrl ?? actorUri, actorUri);
    }

