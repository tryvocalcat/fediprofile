                    </div>
                    <div class="form-group">
                        <input type="text" @bind="_deleteAccountConfirmText" placeholder="Type your username to confirm" class="form-control" />
                    </div>
                    <div style="display:flex;gap:0.5rem;margin-top:0.5rem;">
                        <button class="button button-danger" 
                                @onclick="DeleteMyAccount" 
                                disabled="@(_isProcessing || _deleteAccountConfirmText != _currentUserSlug)">
                            @(_isProcessing ? "Deleting..." : "Permanently Delete Account")
                        </button>
                        <button class="button button-ghost" @onclick="CancelDeleteAccount">
                            Cancel
                        </button>
                    </div>
                }
                    </article>
                </div>
            }
        </div>
    }
</section>



@code {
    [SupplyParameterFromQuery(Name = "impersonate")]
    public string? ImpersonateSlug { get; set; }

    private bool _impersonating;
    private string? _signedInAs;
    private string? _dbName;
    private bool _isProcessing;
    private bool _isRootUser;
    private bool _isAuthorized;
    private string? _currentUserSlug;
    private string? _currentDomain;
    private bool _hideFollowersTab;
    private bool _hideRecentPostsTab;
    private bool _hideSettingsTab;
    private IReadOnlyList<ThemeOption> _availableThemes = Themes.All;
    private Dictionary<string, bool> _allowedThemeSelection = new(StringComparer.OrdinalIgnoreCase);

    // Profile editing fields
    private string? _profileDisplayName;
    private string? _profileBio;
    private string? _profileAvatarUrl;
    private string? _profileTheme;
    private string? _profileMessage;
    private bool _profileIsError;
    private bool _profileSkipReplies;
    private bool _profileShowRecentPosts = true;
    private string _activeAdminTab = "profile";

    // Link fields (new link form)
    private string? _newLinkName;
    private string? _newLinkUrl;
    private string? _selectedIconKey;
    private string? _customIconUrl;
    private string? _newLinkDescription;
    private string? _newLinkCategory;
    private string? _customCategory;
    private bool _newLinkAutoBoost;
    private bool _newLinkHidden;
    private bool _newLinkIconGridOpen;
    private bool _addingNewLink;

    // URL format hints per platform icon
    private static readonly Dictionary<string, (string HandlePrefix, string UrlTemplate, string PlatformName, string Example)> _urlHints = new()
    {
        ["bluesky"]  = ("@", "https://bsky.app/profile/{0}", "Bluesky",  "@user.bsky.social"),
        ["matrix"]   = ("@", "https://matrix.to/#/{0}",      "Matrix",   "@user:matrix.org"),
        ["telegram"] = ("@", "https://t.me/{0}",             "Telegram", "@username"),
    };

    /// <summary>
    /// Checks whether a URL looks like a handle instead of a full URL for the chosen platform icon or link name.
    /// Returns (correctedUrl, warningMessage). If no correction needed both are null.
    /// </summary>
    private static (string? CorrectedUrl, string? Warning) DetectUrlHint(string? iconKey, string? url, string? linkName = null)
    {
        if (string.IsNullOrWhiteSpace(url)) return (null, null);
        var trimmed = url.Trim();

        // If it already looks like a URL, nothing to do
        if (trimmed.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
            trimmed.StartsWith("https://", StringComparison.OrdinalIgnoreCase))
            return (null, null);

        // Detect @user@domain.com webfinger format
        if (IsWebfingerHandle(trimmed))
            return (null, "This looks like a fediverse handle — it will be resolved via WebFinger and saved as the profile URL.");

        // Try to find a matching rule: first by icon key, then by link name
        (string HandlePrefix, string UrlTemplate, string PlatformName, string Example)? matched = null;

        if (!string.IsNullOrEmpty(iconKey) && _urlHints.TryGetValue(iconKey, out var hintByIcon))
        {
            matched = hintByIcon;
        }
        else if (!string.IsNullOrWhiteSpace(linkName))
        {
            foreach (var kvp in _urlHints)
            {
                if (string.Equals(kvp.Value.PlatformName, linkName.Trim(), StringComparison.OrdinalIgnoreCase))
                {
                    matched = kvp.Value;
                    break;
                }
            }
        }

        if (matched is { } hint)
        {
            if (trimmed.StartsWith(hint.HandlePrefix))
            {
                var handle = trimmed.TrimStart('@', '#');
                var corrected = string.Format(hint.UrlTemplate, handle);
                return (corrected, $"This looks like a {hint.PlatformName} handle — the URL will be saved as {corrected}");
            }
        }

        // Generic warning when nothing matched and input looks like a handle
        if (trimmed.StartsWith("@") || trimmed.StartsWith("#"))
            return (null, "This doesn't look like a URL. Select a platform icon (e.g. Bluesky, Matrix) to auto-convert handles, or enter a full URL starting with https://.");

        return (null, null);
    }

    /// <summary>Checks if the input matches the @user@domain.tld webfinger format.</summary>
    private static bool IsWebfingerHandle(string input)
    {
        if (!input.StartsWith("@")) return false;
        var withoutLeadingAt = input.Substring(1);
        var atIdx = withoutLeadingAt.IndexOf('@');
        return atIdx > 0 && atIdx < withoutLeadingAt.Length - 1 && withoutLeadingAt.Substring(atIdx + 1).Contains('.');
    }

    /// <summary>
    /// Resolves a @user@domain.tld handle via WebFinger.
    /// Returns (profileUrl, actorAPUri) or (null, null) on failure.
    /// </summary>
    private static async Task<(string? ProfileUrl, string? ActorUri)> ResolveWebfingerAsync(string handle)
    {
        var withoutLeadingAt = handle.TrimStart('@');
        var atIdx = withoutLeadingAt.IndexOf('@');
        if (atIdx <= 0) return (null, null);
        var domain = withoutLeadingAt.Substring(atIdx + 1);

        var webfingerUrl = $"https://{domain}/.well-known/webfinger?resource=acct:{withoutLeadingAt}";

        using var http = new HttpClient { Timeout = TimeSpan.FromSeconds(10) };
        http.DefaultRequestHeaders.Add("Accept", "application/jrd+json, application/json");
        var resp = await http.GetAsync(webfingerUrl);
        resp.EnsureSuccessStatusCode();

        var json = await resp.Content.ReadAsStringAsync();
        using var doc = System.Text.Json.JsonDocument.Parse(json);

        string? profileUrl = null;
        string? actorUri = null;

        if (doc.RootElement.TryGetProperty("links", out var links))
        {
            foreach (var link in links.EnumerateArray())
            {
                var rel = link.TryGetProperty("rel", out var r) ? r.GetString() : null;
                var type = link.TryGetProperty("type", out var t) ? t.GetString() : null;
                var href = link.TryGetProperty("href", out var h) ? h.GetString() : null;
                if (string.IsNullOrEmpty(href)) continue;

                if (rel == "self" && type != null && type.Contains("activity"))
                    actorUri = href;
                else if (rel == "http://webfinger.net/rel/profile-page")
                    profileUrl = href;
            }
        }

        // Use actor URI as profile URL fallback
        return (profileUrl ?? actorUri, actorUri);
    }

    private async Task<FediProfile.Models.ActivityPubActor?> FetchActivityPubActorAsync(string? publicUrl, string? actorUri)
    {
        if (_currentUserDb == null || string.IsNullOrWhiteSpace(_currentUserSlug)) return null;

        var lookupUrl = !string.IsNullOrWhiteSpace(actorUri) ? actorUri : publicUrl?.Trim();
        if (string.IsNullOrWhiteSpace(lookupUrl)) return null;

        var (_, privKey) = await _currentUserDb.GetActorKeysAsync();
        if (string.IsNullOrEmpty(privKey)) return null;

        var domain = DomainDb.GetDomain() ?? "localhost";
        var httpContext = HttpContextAccessor.HttpContext;
        var scheme = httpContext?.Request.Scheme ?? "https";
        var fullDomain = httpContext?.Request.Host.ToString() ?? domain;
        var actorId = $"{scheme}://{fullDomain}/{_currentUserSlug}";
        var keyId = $"{actorId}#main-key";

        var actorHelper = new FediProfile.Core.ActorHelper(privKey, keyId, Logger);
        return await actorHelper.FetchActorInformationAsync(lookupUrl);
    }

    private async Task<(string PublicUrl, bool IsActivityPub, string? ActorUri)> ResolveActivityPubLinkAsync(string rawUrl)
    {
        var publicUrl = rawUrl.Trim();
        string? actorUri = null;

        if (IsWebfingerHandle(publicUrl))
        {
            try
            {
                var (wfProfileUrl, wfActorUri) = await ResolveWebfingerAsync(publicUrl);
                if (!string.IsNullOrWhiteSpace(wfProfileUrl))
                    publicUrl = wfProfileUrl;
                actorUri = wfActorUri;
            }
            catch (Exception ex)
            {
                Logger.LogInformation("WebFinger resolve failed for {Handle}: {Message}", publicUrl, ex.Message);
            }
        }

        try
        {
            var remoteActor = await FetchActivityPubActorAsync(publicUrl, actorUri);
            if (remoteActor?.Inbox != null)
            {
                actorUri = remoteActor.Id;
                if (!string.IsNullOrWhiteSpace(remoteActor.Url))
                    publicUrl = remoteActor.Url;
                else if (string.IsNullOrWhiteSpace(publicUrl))
                    publicUrl = actorUri;

                return (publicUrl, true, actorUri);
            }
        }
        catch (Exception ex)
        {
            Logger.LogInformation("ActivityPub probe failed for {Url}: {Message}", publicUrl, ex.Message);
        }

        return (publicUrl, !string.IsNullOrWhiteSpace(actorUri), actorUri);
    }

